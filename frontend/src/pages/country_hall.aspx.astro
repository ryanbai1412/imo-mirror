---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { loadParticipants, loadCountries } from "../utils/data";
import { sortData, parseSortParams, getSortUrl, sortIndicator } from "../utils/sort";

const origin = Astro.url.origin;
const code = Astro.url.searchParams.get("code") || "";
if (!code) return Astro.redirect("/countries.aspx");

const [participants, countries] = await Promise.all([
  loadParticipants(origin),
  loadCountries(origin),
]);

const country = countries.find(c => c.code === code);
const { column, order } = parseSortParams(Astro.url.searchParams);

interface HallRow { id: number; name: string; participations: number; gold: number; silver: number; bronze: number; hm: number; total_medals: number; }
const hallMap = new Map<number, HallRow>();
for (const p of Object.values(participants)) {
  for (const r of p.results) {
    if (r.country_code !== code) continue;
    let entry = hallMap.get(p.id);
    if (!entry) {
      entry = { id: p.id, name: p.name, participations: 0, gold: 0, silver: 0, bronze: 0, hm: 0, total_medals: 0 };
      hallMap.set(p.id, entry);
    }
    entry.participations++;
    const award = (r.award || "").toLowerCase();
    if (award.includes("gold")) entry.gold++;
    else if (award.includes("silver")) entry.silver++;
    else if (award.includes("bronze")) entry.bronze++;
    else if (award.includes("honourable") || award.includes("hm")) entry.hm++;
    entry.total_medals = entry.gold + entry.silver + entry.bronze + entry.hm;
  }
}
let rows = Array.from(hallMap.values()).sort((a, b) => b.gold - a.gold || b.silver - a.silver || b.bronze - a.bronze);
if (column) rows = sortData(rows, column, order);
---

<Layout title={`${country?.name || code} — Hall of Fame`} description={`Top IMO performers from ${country?.name || code}. Medal counts and participation history for all contestants.`} path={`/country_hall.aspx?code=${code}`}>
  <div class="page-content">
    <PageHeader title={`${country?.name || code} — Hall of Fame`} navItems={[
      { label: "Overview", href: `/country_info.aspx?code=${code}` },
      { label: "Hall of Fame", href: `/country_hall.aspx?code=${code}` },
      { label: "Individual Results", href: `/country_individual_r.aspx?code=${code}` },
      { label: "Team Results", href: `/country_team_r.aspx?code=${code}` },
    ]} currentPath={`/country_hall.aspx?code=${code}`}>
      <Fragment slot="title">
        {country?.flag_url && <img src={country.flag_url} alt={code} class="country-flag-large" />}
        {country?.name || code} &mdash; Hall of Fame
      </Fragment>
    </PageHeader>

    <p class="page-subtitle">{rows.length} participants with awards</p>

    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th class="sortable-header"><a href={getSortUrl(Astro.url, "name", column, order)}>Name{sortIndicator("name", column, order)}</a></th>
            <th class="text-center sortable-header" title="Participations"><a href={getSortUrl(Astro.url, "participations", column, order, "desc")}>Part.{sortIndicator("participations", column, order)}</a></th>
            <th class="text-center sortable-header" title="Gold medals"><a href={getSortUrl(Astro.url, "gold", column, order, "desc")}>G{sortIndicator("gold", column, order)}</a></th>
            <th class="text-center sortable-header" title="Silver medals"><a href={getSortUrl(Astro.url, "silver", column, order, "desc")}>S{sortIndicator("silver", column, order)}</a></th>
            <th class="text-center sortable-header" title="Bronze medals"><a href={getSortUrl(Astro.url, "bronze", column, order, "desc")}>B{sortIndicator("bronze", column, order)}</a></th>
            <th class="text-center sortable-header" title="Honourable Mention"><a href={getSortUrl(Astro.url, "hm", column, order, "desc")}>HM{sortIndicator("hm", column, order)}</a></th>
            <th class="text-center sortable-header"><a href={getSortUrl(Astro.url, "total_medals", column, order, "desc")}>Total{sortIndicator("total_medals", column, order)}</a></th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <td><a href={`/participant_r.aspx?id=${row.id}`}>{row.name}</a></td>
              <td class="text-center">{row.participations}</td>
              <td class="text-center">{row.gold > 0 ? <span class="award-gold-medal">{row.gold}</span> : ""}</td>
              <td class="text-center">{row.silver > 0 ? <span class="award-silver-medal">{row.silver}</span> : ""}</td>
              <td class="text-center">{row.bronze > 0 ? <span class="award-bronze-medal">{row.bronze}</span> : ""}</td>
              <td class="text-center">{row.hm > 0 ? <span class="award-honourable-mention">{row.hm}</span> : ""}</td>
              <td class="text-center">{row.total_medals}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>
