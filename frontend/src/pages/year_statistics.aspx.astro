---
import Layout from "../layouts/Layout.astro";
import SubNav from "../components/SubNav.astro";
import { loadYearStatistics } from "../utils/data";

const origin = Astro.url.origin;
const year = Astro.url.searchParams.get("year") || "";
if (!year) return Astro.redirect("/results.aspx");

const statsMap = await loadYearStatistics(origin);
const stats = statsMap[year];

const firstRow = stats ? Object.values(stats.problems)[0] : undefined;
const problemKeys = firstRow ? Object.keys(firstRow).sort() : [];
const problemHeaders = problemKeys.map(k => k.toUpperCase());

const allRows = stats ? Object.entries(stats.problems) : [];

const distributionRows = allRows.filter(([label]) => label.startsWith("Num("));
const summaryRows = allRows.filter(([label]) => label.startsWith("Mean(") || label.startsWith("Max(") || label.startsWith("\u03c3("));
const correlationRows = allRows.filter(([label]) => label.startsWith("Corr("));

interface Section {
  title: string;
  rows: [string, Record<string, string>][];
}

const sections: Section[] = [
  { title: "Score Distribution", rows: distributionRows },
  { title: "Summary Statistics", rows: summaryRows },
  { title: "Correlations", rows: correlationRows },
].filter(s => s.rows.length > 0);
---

<Layout title={`IMO ${year} - Statistics`} description={`Score distribution statistics for the ${year} International Mathematical Olympiad. Problem-by-problem analysis.`} path={`/year_statistics.aspx?year=${year}`}>
  <div class="page-content">
    <h2>IMO {year} &mdash; Statistics</h2>
    <SubNav items={[
      { label: "Overview", href: `/year_info.aspx?year=${year}` },
      { label: "Country Results", href: `/year_country_r.aspx?year=${year}` },
      { label: "Individual Results", href: `/year_individual_r.aspx?year=${year}` },
      { label: "Statistics", href: `/year_statistics.aspx?year=${year}` },
    ]} currentPath={`/year_statistics.aspx?year=${year}`} />

    {stats ? (
      sections.map(section => (
        <div class="stats-section">
          <h3>{section.title}</h3>
          <div class="table-container">
            <table class="data-table stats-table">
              <thead>
                <tr>
                  <th></th>
                  {problemHeaders.map(h => (
                    <th class="text-right">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {section.rows.map(([label, values]) => (
                  <tr>
                    <td class="stat-label">{label}</td>
                    {problemKeys.map(key => (
                      <td class="text-right">{values[key]}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      ))
    ) : (
      <p>No statistics available for this year.</p>
    )}
  </div>
</Layout>

<style>
  .stats-section {
    margin-bottom: 2rem;
  }
  .stats-section h3 {
    margin-bottom: 0.75rem;
  }
  .stats-table .stat-label {
    white-space: nowrap;
    font-weight: 500;
  }
  .stats-table td.text-right,
  .stats-table th.text-right {
    text-align: right;
    min-width: 5em;
  }
</style>
