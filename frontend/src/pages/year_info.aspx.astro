---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { loadYearInfo, loadTimeline, formatDate } from "../utils/data";

const origin = Astro.url.origin;
const year = Astro.url.searchParams.get("year") || "";
if (!year) return Astro.redirect("/organizers.aspx");

const [yearInfoMap, timeline] = await Promise.all([
  loadYearInfo(origin),
  loadTimeline(origin),
]);

const info = yearInfoMap[year];
const entry = timeline.find(t => t.year === Number(year));
if (!info && !entry) return Astro.redirect("/organizers.aspx");

const yearNum = Number(year);
const prevYear = timeline.find(t => t.year === yearNum - 1);
const nextYear = timeline.find(t => t.year === yearNum + 1);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Event",
  name: `International Mathematical Olympiad ${year}`,
  startDate: entry?.date || year,
  location: entry ? { "@type": "Place", name: `${entry.city}, ${entry.country}` } : undefined,
};
---

<Layout title={`IMO ${year}`} description={`IMO ${year} held in ${entry?.city || ""}, ${entry?.country || ""}. ${info?.num_contestants || ""} contestants from ${info?.num_countries || ""} countries.`} path={`/year_info.aspx?year=${year}`} jsonLd={jsonLd}>
  <div class="page-content">
    <PageHeader title={`IMO ${year}`} navItems={[
      { label: "Overview", href: `/year_info.aspx?year=${year}` },
      { label: "Country Results", href: `/year_country_r.aspx?year=${year}` },
      { label: "Individual Results", href: `/year_individual_r.aspx?year=${year}` },
      { label: "Statistics", href: `/year_statistics.aspx?year=${year}` },
    ]} currentPath={`/year_info.aspx?year=${year}`}
      prevHref={prevYear ? `/year_info.aspx?year=${prevYear.year}` : undefined}
      nextHref={nextYear ? `/year_info.aspx?year=${nextYear.year}` : undefined}
    />

    {entry && (
      <div class="info-grid">
        <span class="info-label">Edition</span><span class="info-value">{entry.edition}</span>
        <span class="info-label">Location</span><span class="info-value">{entry.city}, {entry.country}</span>
        <span class="info-label">Date</span><span class="info-value">{formatDate(entry.date)}</span>
        {info?.num_countries && <><span class="info-label">Countries</span><span class="info-value">{info.num_countries}</span></>}
        {info?.num_contestants && <><span class="info-label">Contestants</span><span class="info-value">{info.num_contestants}</span></>}
        {info?.homepage && <><span class="info-label">Homepage</span><span class="info-value"><a href={info.homepage} target="_blank" rel="noopener noreferrer">{info.homepage}</a></span></>}
      </div>
    )}

    {info && (
      <div class="medal-summary">
        {info.gold_count != null && (
          <div class="medal-card gold">
            <div class="medal-card-icon gold">G</div>
            <div class="medal-card-info">
              <span class="medal-card-count">{info.gold_count}</span>
              <span class="medal-card-label">Gold</span>
            </div>
            {info.gold_cutoff != null && (
              <div class="medal-card-cutoff gold">&ge; {info.gold_cutoff} pts</div>
            )}
          </div>
        )}
        {info.silver_count != null && (
          <div class="medal-card silver">
            <div class="medal-card-icon silver">S</div>
            <div class="medal-card-info">
              <span class="medal-card-count">{info.silver_count}</span>
              <span class="medal-card-label">Silver</span>
            </div>
            {info.silver_cutoff != null && (
              <div class="medal-card-cutoff silver">&ge; {info.silver_cutoff} pts</div>
            )}
          </div>
        )}
        {info.bronze_count != null && (
          <div class="medal-card bronze">
            <div class="medal-card-icon bronze">B</div>
            <div class="medal-card-info">
              <span class="medal-card-count">{info.bronze_count}</span>
              <span class="medal-card-label">Bronze</span>
            </div>
            {info.bronze_cutoff != null && (
              <div class="medal-card-cutoff bronze">&ge; {info.bronze_cutoff} pts</div>
            )}
          </div>
        )}
        {info.hm_count != null && (
          <div class="medal-card hm">
            <div class="medal-card-icon hm">HM</div>
            <div class="medal-card-info">
              <span class="medal-card-count">{info.hm_count}</span>
              <span class="medal-card-label">Hon. Mention</span>
            </div>
          </div>
        )}
      </div>
    )}
  </div>
</Layout>

<style>
  .medal-summary {
    display: flex; gap: 12px;
    flex-wrap: wrap; margin: 20px 0;
  }
  .medal-card {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 16px; background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    border-left: 4px solid var(--border);
    box-shadow: var(--shadow-sm); min-width: 160px;
    transition: all var(--transition);
  }
  .medal-card:hover { box-shadow: var(--shadow); }
  .medal-card.gold { border-left-color: #d4a017; }
  .medal-card.silver { border-left-color: #9ca3af; }
  .medal-card.bronze { border-left-color: #c47a2e; }
  .medal-card.hm { border-left-color: #34d399; }
  .medal-card-icon {
    width: 34px; height: 34px; border-radius: 50%;
    display: flex; align-items: center;
    justify-content: center;
    font-weight: 700; font-size: 13px;
    flex-shrink: 0;
  }
  .medal-card-icon.gold {
    background: var(--medal-gold-bg);
    color: var(--medal-gold-fg);
  }
  .medal-card-icon.silver {
    background: var(--medal-silver-bg);
    color: var(--medal-silver-fg);
  }
  .medal-card-icon.bronze {
    background: var(--medal-bronze-bg);
    color: var(--medal-bronze-fg);
  }
  .medal-card-icon.hm {
    background: var(--medal-hm-bg);
    color: var(--medal-hm-fg);
  }
  .medal-card-info {
    display: flex; flex-direction: column;
  }
  .medal-card-count {
    font-weight: 700; font-size: 20px;
    line-height: 1.2; color: var(--navy);
  }
  .medal-card-label {
    font-size: 11px; color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .medal-card-cutoff {
    margin-left: auto; padding: 4px 12px;
    border-radius: var(--radius-badge);
    font-size: 13px; font-weight: 700;
    white-space: nowrap;
  }
  .medal-card-cutoff.gold {
    background: var(--medal-gold-bg);
    color: var(--medal-gold-fg);
  }
  .medal-card-cutoff.silver {
    background: var(--medal-silver-bg);
    color: var(--medal-silver-fg);
  }
  .medal-card-cutoff.bronze {
    background: var(--medal-bronze-bg);
    color: var(--medal-bronze-fg);
  }
  @media (max-width: 768px) {
    .medal-summary { flex-direction: column; }
  }
</style>
