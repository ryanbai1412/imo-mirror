---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { loadIndividualResultsByYear, loadCountries } from "../utils/data";
import { sortData, parseSortParams, getSortUrl, sortIndicator } from "../utils/sort";
import { awardClass } from "../utils/awardClass";

const origin = Astro.url.origin;
const code = Astro.url.searchParams.get("code") || "";
if (!code) return Astro.redirect("/countries.aspx");

const [individualResults, countries] = await Promise.all([
  loadIndividualResultsByYear(origin),
  loadCountries(origin),
]);

const country = countries.find(c => c.code === code);
const { column, order } = parseSortParams(Astro.url.searchParams);

interface IndivRow { year: number; name: string; participant_id: number | null; p1: number | null; p2: number | null; p3: number | null; p4: number | null; p5: number | null; p6: number | null; total: number | null; rank: number | null; award: string; }
const allRows: IndivRow[] = [];
for (const [year, results] of Object.entries(individualResults)) {
  for (const r of results) {
    if (r.country_code === code) {
      allRows.push({ year: Number(year), name: r.name, participant_id: r.participant_id, p1: r.p1, p2: r.p2, p3: r.p3, p4: r.p4, p5: r.p5, p6: r.p6, total: r.total, rank: r.rank, award: r.award });
    }
  }
}
allRows.sort((a, b) => b.year - a.year || a.name.localeCompare(b.name));
const rows = column ? sortData(allRows, column, order) : allRows;
---

<Layout title={`${country?.name || code} — Individual Results`} description={`All individual IMO results for ${country?.name || code}. Problem scores, totals, ranks, and awards for every contestant.`} path={`/country_individual_r.aspx?code=${code}`}>
  <div class="page-content">
    <PageHeader title={`${country?.name || code} — Individual Results`} navItems={[
      { label: "Overview", href: `/country_info.aspx?code=${code}` },
      { label: "Hall of Fame", href: `/country_hall.aspx?code=${code}` },
      { label: "Individual Results", href: `/country_individual_r.aspx?code=${code}` },
      { label: "Team Results", href: `/country_team_r.aspx?code=${code}` },
    ]} currentPath={`/country_individual_r.aspx?code=${code}`}>
      <Fragment slot="title">
        {country?.flag_url && <img src={country.flag_url} alt={code} class="country-flag-large" />}
        {country?.name || code} &mdash; Individual Results
      </Fragment>
    </PageHeader>

    <p class="page-subtitle">{rows.length} individual results</p>

    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th class="text-center sortable-header"><a href={getSortUrl(Astro.url, "year", column, order)}>Year{sortIndicator("year", column, order)}</a></th>
            <th class="sortable-header"><a href={getSortUrl(Astro.url, "name", column, order)}>Contestant{sortIndicator("name", column, order)}</a></th>
            <th class="text-center" title="Problem 1">P1</th><th class="text-center" title="Problem 2">P2</th><th class="text-center" title="Problem 3">P3</th>
            <th class="text-center" title="Problem 4">P4</th><th class="text-center" title="Problem 5">P5</th><th class="text-center" title="Problem 6">P6</th>
            <th class="text-center sortable-header"><a href={getSortUrl(Astro.url, "total", column, order, "desc")}>Total{sortIndicator("total", column, order)}</a></th>
            <th class="text-center sortable-header"><a href={getSortUrl(Astro.url, "rank", column, order)}>Rank{sortIndicator("rank", column, order)}</a></th>
            <th>Award</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr class:list={[i > 0 && rows[i - 1].year !== row.year && "year-group-start"]}>
              <td class="text-center"><a href={`/year_individual_r.aspx?year=${row.year}`}>{row.year}</a></td>
              <td>{row.participant_id ? <a href={`/participant_r.aspx?id=${row.participant_id}`}>{row.name}</a> : row.name}</td>
              <td class="text-center">{row.p1 ?? ""}</td>
              <td class="text-center">{row.p2 ?? ""}</td>
              <td class="text-center">{row.p3 ?? ""}</td>
              <td class="text-center">{row.p4 ?? ""}</td>
              <td class="text-center">{row.p5 ?? ""}</td>
              <td class="text-center">{row.p6 ?? ""}</td>
              <td class="text-center">{row.total ?? ""}</td>
              <td class="text-center">{row.rank ?? ""}</td>
              <td><span class={awardClass(row.award)}>{row.award}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>
