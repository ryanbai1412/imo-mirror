---
import Layout from "../layouts/Layout.astro";
import { loadStaticPages } from "../utils/data";

const origin = Astro.url.origin;
const pages = await loadStaticPages(origin);
const page = pages["links"];
---

<Layout title={page?.title || "Links"} description={`${page?.title || "Links"} — International Mathematical Olympiad official information and guidelines.`} path="/links.aspx">
  <div class="page-content">
    {page ? (
      <>
        <h2>{page.title}</h2>
        <div class="static-content" set:html={page.content} />
      </>
    ) : (
      <h2>Page Not Found</h2>
    )}
  </div>
</Layout>
