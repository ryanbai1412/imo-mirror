---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { loadCountryResultsByYear, loadYearInfo, loadTimeline } from "../utils/data";
import { sortData, parseSortParams, getSortUrl, sortIndicator } from "../utils/sort";
import { CHART_COLORS } from "../utils/chartColors";

const origin = Astro.url.origin;
const year = Astro.url.searchParams.get("year") || "";
if (!year) return Astro.redirect("/results.aspx");

const [countryResults, yearInfoMap, timeline] = await Promise.all([
  loadCountryResultsByYear(origin),
  loadYearInfo(origin),
  loadTimeline(origin),
]);

const results = countryResults[year] || [];
const info = yearInfoMap[year];
const yearNum = Number(year);
const prevYear = timeline.find(t => t.year === yearNum - 1);
const nextYear = timeline.find(t => t.year === yearNum + 1);
const { column, order } = parseSortParams(Astro.url.searchParams);
const sorted = column ? sortData(results, column, order) : results;

const binSize = 10;
const maxPossible = 252;
const numBins = Math.ceil(maxPossible / binSize) + 1;
const countryBins: number[] = Array(numBins).fill(0);
for (const r of results) {
  if (r.total == null) continue;
  const bin = Math.min(Math.floor(r.total / binSize), numBins - 1);
  countryBins[bin]++;
}
const countryDistData = JSON.stringify(
  countryBins.map((count, i) => ({
    label: `${i * binSize}–${i * binSize + binSize - 1}`,
    lo: i * binSize,
    count,
  }))
);
const chartColorsJson = JSON.stringify(CHART_COLORS);

const cols = [
  { key: "rank", label: "Rank", align: "center" },
  { key: "country", label: "Country" },
  { key: "code", label: "Code" },
  { key: "team_size_all", label: "#", title: "Team size", align: "center", defaultOrder: "desc" as const },
  { key: "p1", label: "P1", title: "Problem 1", align: "center", defaultOrder: "desc" as const },
  { key: "p2", label: "P2", title: "Problem 2", align: "center", defaultOrder: "desc" as const },
  { key: "p3", label: "P3", title: "Problem 3", align: "center", defaultOrder: "desc" as const },
  { key: "p4", label: "P4", title: "Problem 4", align: "center", defaultOrder: "desc" as const },
  { key: "p5", label: "P5", title: "Problem 5", align: "center", defaultOrder: "desc" as const },
  { key: "p6", label: "P6", title: "Problem 6", align: "center", defaultOrder: "desc" as const },
  { key: "total", label: "Total", align: "center", defaultOrder: "desc" as const },
  { key: "awards_gold", label: "G", title: "Gold medals", align: "center", defaultOrder: "desc" as const },
  { key: "awards_silver", label: "S", title: "Silver medals", align: "center", defaultOrder: "desc" as const },
  { key: "awards_bronze", label: "B", title: "Bronze medals", align: "center", defaultOrder: "desc" as const },
  { key: "awards_hm", label: "HM", title: "Honourable Mention", align: "center", defaultOrder: "desc" as const },
  { key: "leader", label: "Leader" },
  { key: "deputy_leader", label: "Deputy Leader" },
];
---

<Layout title={`IMO ${year} - Country Results`} description={`Country results for the ${year} International Mathematical Olympiad. Rankings, scores, and medal counts for all participating countries.`} path={`/year_country_r.aspx?year=${year}`}>
  <div class="page-content">
    <PageHeader title={`IMO ${year} — Country Results`} navItems={[
      { label: "Overview", href: `/year_info.aspx?year=${year}` },
      { label: "Country Results", href: `/year_country_r.aspx?year=${year}` },
      { label: "Individual Results", href: `/year_individual_r.aspx?year=${year}` },
      { label: "Statistics", href: `/year_statistics.aspx?year=${year}` },
    ]} currentPath={`/year_country_r.aspx?year=${year}`}
      prevHref={prevYear ? `/year_country_r.aspx?year=${prevYear.year}` : undefined}
      nextHref={nextYear ? `/year_country_r.aspx?year=${nextYear.year}` : undefined}
    />

    {results.length > 0 && (
      <div class="stats-section">
        <h3>Country Score Distribution</h3>
        <div class="chart-wrapper">
          <canvas id="country-dist-chart" width="700" height="320"></canvas>
        </div>
      </div>
    )}

    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            {cols.map(col => (
              <th class:list={[col.align === "center" && "text-center", "sortable-header"]} title={col.title}>
                <a href={getSortUrl(Astro.url, col.key, column, order, col.defaultOrder)}>{col.label}{sortIndicator(col.key, column, order)}</a>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {sorted.map((row) => (
            <tr>
              <td class="text-center">{row.rank ?? ""}</td>
              <td><a href={`/country_info.aspx?code=${row.code}`}>{row.country}</a></td>
              <td><a href={`/country_info.aspx?code=${row.code}`}>{row.code}</a></td>
              <td class="text-center">{row.team_size_all ?? ""}</td>
              <td class="text-center">{row.p1 ?? ""}</td>
              <td class="text-center">{row.p2 ?? ""}</td>
              <td class="text-center">{row.p3 ?? ""}</td>
              <td class="text-center">{row.p4 ?? ""}</td>
              <td class="text-center">{row.p5 ?? ""}</td>
              <td class="text-center">{row.p6 ?? ""}</td>
              <td class="text-center">{row.total ?? ""}</td>
              <td class="text-center">{row.awards_gold ? <span class="award-gold-medal">{row.awards_gold}</span> : ""}</td>
              <td class="text-center">{row.awards_silver ? <span class="award-silver-medal">{row.awards_silver}</span> : ""}</td>
              <td class="text-center">{row.awards_bronze ? <span class="award-bronze-medal">{row.awards_bronze}</span> : ""}</td>
              <td class="text-center">{row.awards_hm ? <span class="award-honourable-mention">{row.awards_hm}</span> : ""}</td>
              <td>{row.leader || ""}</td>
              <td>{row.deputy_leader || ""}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script define:vars={{ countryDistData, year, chartColorsJson }}>
function drawCountryDistChart() {
  const data = JSON.parse(countryDistData);
  const canvas = document.getElementById('country-dist-chart');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  const W = 700, H = 320;
  canvas.width = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);

  const pad = { top: 30, right: 16, bottom: 48, left: 40 };
  const cw = W - pad.left - pad.right;
  const ch = H - pad.top - pad.bottom;

  const last = data.findLastIndex(d => d.count > 0);
  const visible = data.slice(0, Math.max(last + 2, 10));

  const maxCount = visible.reduce((m, d) => Math.max(m, d.count), 0);
  const yMax = Math.ceil(maxCount / 5) * 5 || 5;
  const barW = cw / visible.length;
  const gap = Math.max(1, barW * 0.15);

  const CC = JSON.parse(chartColorsJson);

  ctx.fillStyle = CC.bg;
  ctx.fillRect(0, 0, W, H);

  ctx.strokeStyle = CC.grid;
  ctx.lineWidth = 0.5;
  ctx.font = '11px system-ui, sans-serif';
  ctx.fillStyle = CC.label;
  ctx.textAlign = 'right';
  const ticks = 5;
  for (let i = 0; i <= ticks; i++) {
    const v = Math.round(yMax * i / ticks);
    const y = pad.top + ch - (v / yMax) * ch;
    ctx.beginPath();
    ctx.moveTo(pad.left, y);
    ctx.lineTo(W - pad.right, y);
    ctx.stroke();
    ctx.fillText(String(v), pad.left - 6, y + 4);
  }

  for (let i = 0; i < visible.length; i++) {
    const d = visible[i];
    const x = pad.left + i * barW + gap / 2;
    const bw = barW - gap;
    if (d.count > 0) {
      const h = (d.count / yMax) * ch;
      ctx.fillStyle = CC.line;
      ctx.fillRect(x, pad.top + ch - h, bw, h);
    }
    ctx.fillStyle = CC.label;
    ctx.textAlign = 'center';
    ctx.font = '10px system-ui, sans-serif';
    ctx.fillText(String(d.lo),
      x + bw / 2, pad.top + ch + 14);
  }

  ctx.fillStyle = CC.title;
  ctx.font = 'bold 13px system-ui, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('Country total score — IMO ' + year,
    W / 2, pad.top - 10);
  ctx.font = '11px system-ui, sans-serif';
  ctx.fillStyle = CC.label;
  ctx.fillText('Total Score', W / 2, H - 4);

  const existing = canvas.parentElement.querySelector('.chart-tooltip');
  if (existing) existing.remove();
  const tip = document.createElement('div');
  tip.className = 'chart-tooltip';
  canvas.parentElement.appendChild(tip);
  let lastIdx = -1;
  canvas.addEventListener('mousemove', function(e) {
    const rect = canvas.getBoundingClientRect();
    const mx = (e.clientX - rect.left) * (W / rect.width);
    const my = (e.clientY - rect.top) * (H / rect.height);
    const idx = Math.floor((mx - pad.left) / barW);
    if (idx < 0 || idx >= visible.length || my > pad.top + ch) {
      tip.classList.remove('visible'); lastIdx = -1; return;
    }
    const d0 = visible[idx];
    if (!d0.count) {
      tip.classList.remove('visible'); lastIdx = -1; return;
    }
    const barH = (d0.count / yMax) * ch;
    if (my < pad.top + ch - barH) {
      tip.classList.remove('visible'); lastIdx = -1; return;
    }
    const ox = canvas.offsetLeft;
    const oy = canvas.offsetTop;
    const curX = e.clientX - rect.left;
    const wrapW = canvas.parentElement.offsetWidth;
    const tx = (ox + curX + 160 > wrapW) ? ox + curX - 12 : ox + curX + 12;
    const ty = oy + (e.clientY - rect.top) - 10;
    tip.style.transform = (ox + curX + 160 > wrapW) ? 'translateX(-100%)' : '';
    if (idx === lastIdx) {
      tip.style.left = tx + 'px';
      tip.style.top = ty + 'px';
      return;
    }
    lastIdx = idx;
    const d = visible[idx];
    tip.innerHTML = '<b>' + d.label + ' pts</b><br>'
      + d.count + ' countries';
    tip.classList.add('visible');
    tip.style.left = tx + 'px';
    tip.style.top = ty + 'px';
  });
  canvas.addEventListener('mouseleave', function() {
    tip.classList.remove('visible'); lastIdx = -1;
  });
}
drawCountryDistChart();
document.addEventListener('astro:page-load', drawCountryDistChart);
</script>
