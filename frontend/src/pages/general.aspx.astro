---
import Layout from "../layouts/Layout.astro";
import SubNav from "../components/SubNav.astro";
import { loadStaticPages } from "../utils/data";

const origin = Astro.url.origin;
const pages = await loadStaticPages(origin);
const page = pages["general"];
---

<Layout title={page?.title || "General"} description={`${page?.title || "General"} — International Mathematical Olympiad official information and guidelines.`} path="/general.aspx">
  <div class="page-content">
    {page ? (
      <>
        <h2>{page.title}</h2>
        <SubNav items={[
          { label: "About", href: "/general.aspx" },
          { label: "Links", href: "/links.aspx" },
          { label: "Advisory Board", href: "/advisory.aspx" },
          { label: "Ethics", href: "/ethics.aspx" },
          { label: "Documents", href: "/documents.aspx" },
        ]} currentPath="/general.aspx" />
        <div class="static-content" set:html={page.content} />
      </>
    ) : (
      <h2>Page Not Found</h2>
    )}
  </div>
</Layout>
