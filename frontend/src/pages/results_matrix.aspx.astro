---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { loadResultsMatrix, loadTimeline, isIndividualContestant } from "../utils/data";

const origin = Astro.url.origin;
const [matrix, timeline] = await Promise.all([
  loadResultsMatrix(origin),
  loadTimeline(origin),
]);

const years = timeline
  .filter(t => t.contestants_all && t.contestants_all > 0)
  .map(t => t.year)
  .sort((a, b) => b - a);

const codes = Object.keys(matrix).filter(c => !isIndividualContestant(c)).sort();
const filterCode = Astro.url.searchParams.get("code") || "";
const filteredCodes = filterCode ? codes.filter(c => c === filterCode) : codes;
---

<Layout title="Results Matrix" description="Visual matrix of IMO country rankings across all years. Quick overview of every country's performance history." path="/results_matrix.aspx">
  <div class="page-content">
    <PageHeader title="Results Matrix" navItems={[
      { label: "By Country", href: "/results.aspx" },
      { label: "By Year", href: "/results.aspx?view=year" },
      { label: "Results Matrix", href: "/results_matrix.aspx" },
    ]} currentPath="/results_matrix.aspx" />

    <div class="matrix-container">
      <table class="data-table matrix-table">
        <thead>
          <tr>
            <th class="sticky-col">Country</th>
            {years.map(y => (
              <th class="text-center matrix-year">
                <a href={`/year_info.aspx?year=${y}`}>{String(y).slice(2)}</a>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {filteredCodes.map(code => {
            const entry = matrix[code];
            return (
              <tr>
                <td class="sticky-col">
                  <a href={`/country_info.aspx?code=${code}`}>{code}</a>
                </td>
                {years.map(y => {
                  const rank = entry?.[String(y)];
                  return <td class="text-center matrix-cell">{rank != null ? rank : ""}</td>;
                })}
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<style>
  .matrix-container {
    overflow: auto; max-width: 100%;
    max-height: calc(100vh - 120px);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .matrix-table th {
    top: 0;
  }
  .matrix-table { font-size: 11px; }
  .matrix-table th, .matrix-table td {
    padding: 3px 5px; white-space: nowrap;
  }
  .matrix-year {
    writing-mode: vertical-rl;
    text-orientation: mixed; min-width: 22px;
  }
  .sticky-col {
    position: sticky; left: 0;
    background: var(--surface); z-index: 1;
    border-right: 2px solid var(--border);
  }
  thead .sticky-col {
    background: var(--navy); z-index: 3;
  }
  :global(.matrix-table tbody tr:nth-child(even)) .sticky-col {
    background: var(--table-stripe);
  }
  :global(.matrix-table tbody tr:hover) .sticky-col {
    background: var(--table-hover);
  }
</style>
