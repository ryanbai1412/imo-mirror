---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { loadCountryResultsByYear, loadCountries, loadTimeline, type CountryTeamRow } from "../utils/data";
import { sortData, parseSortParams } from "../utils/sort";
import SortableTableHead from "../components/SortableTableHead.astro";
import { CHART_COLORS } from "../utils/chartColors";
import ChartLegend from "../components/ChartLegend.astro";
import { countryNavItems } from "../utils/nav";

const origin = Astro.url.origin;
const code = Astro.url.searchParams.get("code") || "";
if (!code) return Astro.redirect("/countries.aspx");

const [countryResults, countries, timeline] = await Promise.all([
  loadCountryResultsByYear(origin),
  loadCountries(origin),
  loadTimeline(origin),
]);

const country = countries.find(c => c.code === code);
const { column, order } = parseSortParams(Astro.url.searchParams);

const allRows: CountryTeamRow[] = [];
for (const [year, results] of Object.entries(countryResults)) {
  const match = results.find(r => r.code === code);
  if (match) {
    allRows.push({ year: Number(year), team_size_all: match.team_size_all, p1: match.p1, p2: match.p2, p3: match.p3, p4: match.p4, p5: match.p5, p6: match.p6, p7: match.p7, total: match.total, rank: match.rank, awards_gold: match.awards_gold, awards_silver: match.awards_silver, awards_bronze: match.awards_bronze, awards_hm: match.awards_hm, leader: match.leader, deputy_leader: match.deputy_leader });
  }
}
allRows.sort((a, b) => b.year - a.year);
const rows = column ? sortData(allRows, column, order) : allRows;

const hasP7 = allRows.some(r => r.p7 != null);

const cols = [
  { key: "year", label: "Year", align: "center" },
  { key: "team_size_all", label: "#", title: "Team size", align: "center", sortable: false },
  { key: "p1", label: "P1", title: "Problem 1", align: "center", sortable: false },
  { key: "p2", label: "P2", title: "Problem 2", align: "center", sortable: false },
  { key: "p3", label: "P3", title: "Problem 3", align: "center", sortable: false },
  { key: "p4", label: "P4", title: "Problem 4", align: "center", sortable: false },
  { key: "p5", label: "P5", title: "Problem 5", align: "center", sortable: false },
  { key: "p6", label: "P6", title: "Problem 6", align: "center", sortable: false },
  ...(hasP7 ? [{ key: "p7", label: "P7", title: "Problem 7", align: "center", sortable: false }] : []),
  { key: "total", label: "Total", align: "center", defaultOrder: "desc" as const },
  { key: "rank", label: "Rank", align: "center" },
  { key: "awards_gold", label: "G", title: "Gold medals", align: "center", sortable: false },
  { key: "awards_silver", label: "S", title: "Silver medals", align: "center", sortable: false },
  { key: "awards_bronze", label: "B", title: "Bronze medals", align: "center", sortable: false },
  { key: "awards_hm", label: "HM", title: "Honourable Mention", align: "center", sortable: false },
  { key: "leader", label: "Leader", sortable: false },
  { key: "deputy_leader", label: "Deputy Leader", sortable: false },
];

const timelineByYear = new Map(timeline.map(t => [t.year, t]));
const chartPoints = allRows
  .map(r => ({
    year: r.year,
    edition: timelineByYear.get(r.year)?.edition ?? null,
    numCountries: timelineByYear.get(r.year)?.num_countries ?? null,
    rank: r.rank,
  }))
  .filter(p => p.edition != null)
  .sort((a, b) => a.edition! - b.edition!);
const teamChartData = JSON.stringify(chartPoints);

const medalPoints = allRows
  .slice().sort((a, b) => a.year - b.year)
  .map(r => ({
    year: r.year,
    gold: r.awards_gold ?? 0,
    silver: r.awards_silver ?? 0,
    bronze: r.awards_bronze ?? 0,
    hm: r.awards_hm ?? 0,
  }));
const medalChartData = JSON.stringify(medalPoints);
const chartColorsJson = JSON.stringify(CHART_COLORS);
---

<Layout title={`${country?.name || code} — Team Results`} description={`IMO team results for ${country?.name || code}. Yearly rankings, scores, medal counts, and team leaders.`} path={`/country_team_r.aspx?code=${code}`}>
  <div class="page-content">
    <PageHeader title={`${country?.name || code} — Team Results`} navItems={countryNavItems(code)} currentPath={`/country_team_r.aspx?code=${code}`}>
      <Fragment slot="title">
        {country?.flag_url && <img src={country.flag_url} alt={code} class="country-flag-large" />}
        {country?.name || code} &mdash; Team Results
      </Fragment>
    </PageHeader>

    {medalPoints.length > 1 && chartPoints.length > 1 && (
      <div class="charts-row">
        <div class="stats-section">
          <h3>Medal Counts</h3>
          <div class="chart-wrapper">
            <canvas id="medal-count-chart" width="700" height="320"></canvas>
          </div>
          <ChartLegend items={[
            { color: CHART_COLORS.gold, label: "Gold" },
            { color: CHART_COLORS.silver, label: "Silver" },
            { color: CHART_COLORS.bronze, label: "Bronze" },
            { color: CHART_COLORS.hm, label: "HM" },
          ]} />
        </div>
        <div class="stats-section">
          <h3>Team Ranking</h3>
          <div class="chart-wrapper">
            <canvas id="team-rank-chart" width="700" height="320"></canvas>
          </div>
          <ChartLegend items={[
            { color: CHART_COLORS.gold, label: "Participating countries" },
            { color: CHART_COLORS.line, label: "Ranking", line: true },
          ]} />
        </div>
      </div>
    )}

    <div class="table-container">
      <table class="data-table">
        <SortableTableHead cols={cols} url={Astro.url} column={column} order={order} />
        <tbody>
          {rows.map((row) => (
            <tr>
              <td class="text-center"><a href={`/team_r.aspx?code=${code}&year=${row.year}`}>{row.year}</a></td>
              <td class="text-center">{row.team_size_all ?? ""}</td>
              <td class="text-center">{row.p1 ?? ""}</td>
              <td class="text-center">{row.p2 ?? ""}</td>
              <td class="text-center">{row.p3 ?? ""}</td>
              <td class="text-center">{row.p4 ?? ""}</td>
              <td class="text-center">{row.p5 ?? ""}</td>
              <td class="text-center">{row.p6 ?? ""}</td>
              {hasP7 && <td class="text-center">{row.p7 ?? ""}</td>}
              <td class="text-center">{row.total ?? ""}</td>
              <td class="text-center">{row.rank ?? ""}</td>
              <td class="text-center">{row.awards_gold ? <span class="award-gold-medal">{row.awards_gold}</span> : ""}</td>
              <td class="text-center">{row.awards_silver ? <span class="award-silver-medal">{row.awards_silver}</span> : ""}</td>
              <td class="text-center">{row.awards_bronze ? <span class="award-bronze-medal">{row.awards_bronze}</span> : ""}</td>
              <td class="text-center">{row.awards_hm ? <span class="award-honourable-mention">{row.awards_hm}</span> : ""}</td>
              <td>{row.leader}</td>
              <td>{row.deputy_leader}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ teamChartData, medalChartData, code, chartColorsJson }}>
var CC = JSON.parse(chartColorsJson);
function drawTeamRankChart() {
  var data = JSON.parse(teamChartData);
  var pad = { top: 30, right: 16, bottom: 36, left: 40 };
  var c = chartSetup('team-rank-chart', CC, 0, 320, pad);
  if (!c || !data.length) return;
  var ctx = c.ctx, canvas = c.canvas;
  var cw = c.cw, ch = c.ch, W = c.W, H = c.H;
  var maxCountries = data.reduce(function(m, d) { return Math.max(m, d.numCountries || 0); }, 0);
  var yMax = Math.ceil(maxCountries / 10) * 10 || 10;
  var barW = cw / data.length;
  var gap = Math.max(1, barW * 0.15);
  drawYGrid(ctx, CC, pad, W, ch, yMax);
  // Simple single-color bars for country count
  for (var i = 0; i < data.length; i++) {
    var d = data[i];
    if (d.numCountries) {
      var x = pad.left + i * barW + gap / 2;
      var bw = barW - gap;
      var h = (d.numCountries / yMax) * ch;
      ctx.fillStyle = CC.gold;
      ctx.fillRect(x, pad.top + ch - h, bw, h);
    }
  }
  // Rank overlay line + dots
  drawRankOverlay(ctx, CC, data, pad, ch, barW, gap, yMax, 'rank', function(d) { return d.numCountries || 0; });
  drawXLabels(ctx, CC, data, pad, ch, barW);
  drawTitle(ctx, CC, 'Team ranking - ' + code, W, pad);
  setupTooltip(canvas, data, W, H, pad, ch, {
    getIdx: barGetIdx(pad, barW),
    isHidden: function(my, idx) {
      var barH = data[idx].numCountries ? (data[idx].numCountries / yMax) * ch : 0;
      return my < pad.top + ch - barH;
    },
    getHtml: function(d) {
      var html = '<b>IMO ' + d.year + '</b><br>';
      if (d.numCountries != null) html += 'Countries: ' + d.numCountries + '<br>';
      if (d.rank != null) html += rankLabel(d.rank) + ' / ' + (d.numCountries || '?');
      return html;
    }
  });
}
function drawMedalCountChart() {
  var data = JSON.parse(medalChartData);
  var layers = [
    { key: 'gold', color: CC.gold }, { key: 'silver', color: CC.silver },
    { key: 'bronze', color: CC.bronze }, { key: 'hm', color: CC.hm },
  ];
  drawMedalStackedChart('medal-count-chart', data, CC, layers, { yStep: 2 });
}
drawTeamRankChart();
drawMedalCountChart();
document.addEventListener('astro:page-load', function() {
  drawTeamRankChart();
  drawMedalCountChart();
});
</script>
