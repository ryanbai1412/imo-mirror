---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found" description="The requested page was not found on IMO Mirror.">
  <div class="page-content">
    <h2>Page Not Found</h2>
    <p>Sorry, the page you're looking for doesn't exist or may have been removed.</p>
    <p>Here are some places you can go instead:</p>
    <div class="not-found-links">
      <a href="/" class="btn btn-primary btn--pill">Homepage</a>
      <a href="/organizers.aspx" class="btn btn-primary btn--pill">Timeline</a>
      <a href="/countries.aspx" class="btn btn-primary btn--pill">Countries</a>
      <a href="/results.aspx" class="btn btn-primary btn--pill">Results</a>
      <a href="/hall.aspx" class="btn btn-primary btn--pill">Hall of Fame</a>
      <a href="/search.aspx" class="btn btn-primary btn--pill">Search Participants</a>
    </div>
  </div>
</Layout>

<style>
  .not-found-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
  }
  .not-found-links .btn:hover {
    color: var(--gold-light);
  }
</style>
