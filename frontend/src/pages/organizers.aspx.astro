---
import Layout from "../layouts/Layout.astro";
import { loadTimeline, loadCountries, formatDate } from "../utils/data";
import { sortData, parseSortParams } from "../utils/sort";
import SortableTableHead from "../components/SortableTableHead.astro";
import ChartLegend from "../components/ChartLegend.astro";
import { CHART_COLORS } from "../utils/chartColors";

const origin = Astro.url.origin;
const [timeline, countries] = await Promise.all([
  loadTimeline(origin),
  loadCountries(origin),
]);
const nameToCode = new Map(countries.map(c => [c.name, c.code]));
const { column, order } = parseSortParams(Astro.url.searchParams);
const sorted = column ? sortData(timeline, column, order) : timeline;

const chrono = [...timeline]
  .filter(t => t.num_countries != null)
  .sort((a, b) => a.year - b.year);
const growthData = JSON.stringify(chrono.map(t => ({
  year: t.year,
  countries: t.num_countries ?? 0,
  contestants: t.contestants_all ?? 0,
})));
const chartColorsJson = JSON.stringify(CHART_COLORS);

const cols = [
  { key: "edition", label: "#", title: "Edition number", align: "center" },
  { key: "year", label: "Year", align: "center" },
  { key: "country", label: "Country" },
  { key: "city", label: "City" },
  { key: "num_countries", label: "Countries", align: "center", defaultOrder: "desc" as const },
  { key: "contestants_all", label: "Contestants", align: "center", defaultOrder: "desc" as const },
  { key: "date", label: "Date", sortable: false },
];
---

<Layout title="Timeline" description="Complete timeline of every International Mathematical Olympiad from 1959 to present. Host cities, dates, and participation statistics." path="/organizers.aspx">
  <div class="page-content">
    <h2>Timeline</h2>

    {chrono.length > 1 && (
      <div class="stats-section">
        <h3>Participation Growth</h3>
        <div class="chart-wrapper">
          <canvas id="growth-chart" width="900" height="320"></canvas>
        </div>
        <ChartLegend items={[
          { color: CHART_COLORS.line, label: "Countries", line: true },
          { color: "#b45309", label: "Contestants", line: true },
        ]} />
      </div>
    )}

    <div class="table-container">
      <table class="data-table">
        <SortableTableHead cols={cols} url={Astro.url} column={column} order={order} />
        <tbody>
          {sorted.map((entry) => (
            <tr>
              <td class="text-center">{entry.edition}</td>
              <td class="text-center"><a href={`/year_info.aspx?year=${entry.year}`}>{entry.year}</a></td>
              <td>{nameToCode.has(entry.country) ? <a href={`/country_info.aspx?code=${nameToCode.get(entry.country)}`}>{entry.country}</a> : entry.country}</td>
              <td>{entry.city}</td>
              <td class="text-center">{entry.num_countries ?? ""}</td>
              <td class="text-center">{entry.contestants_all ?? ""}</td>
              <td>{formatDate(entry.date)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ growthData, chartColorsJson }}>
var CC = JSON.parse(chartColorsJson);
function drawGrowthChart() {
  var data = JSON.parse(growthData);
  var pad = { top: 20, right: 52, bottom: 36, left: 46 };
  var c = chartSetup('growth-chart', CC, 0, 320, pad);
  if (!c || !data.length) return;
  var ctx = c.ctx, canvas = c.canvas, cw = c.cw, ch = c.ch, W = c.W, H = c.H;

  var cVals = data.map(function(d) { return d.countries; });
  var tVals = data.map(function(d) { return d.contestants; });
  var cMax = Math.max.apply(null, cVals);
  var tMax = Math.max.apply(null, tVals);
  var cStep = cMax > 50 ? 20 : 10;
  var tStep = tMax > 500 ? 100 : tMax > 200 ? 50 : 20;
  var yMaxL = Math.ceil(cMax / cStep) * cStep || cStep;
  var yMaxR = Math.ceil(tMax / tStep) * tStep || tStep;

  drawYGrid(ctx, CC, pad, W, ch, yMaxL);
  drawYGridRight(ctx, CC, pad, W, ch, yMaxR);

  drawLineChart(ctx, data, pad, cw, ch, yMaxL, 'countries', CC.line);

  var xScale = function(i) { return pad.left + (i / Math.max(1, data.length - 1)) * cw; };
  var yScaleR = function(v) { return pad.top + ch - (v / yMaxR) * ch; };
  var contestantColor = '#b45309';
  ctx.beginPath();
  ctx.moveTo(xScale(0), pad.top + ch);
  for (var i = 0; i < data.length; i++) {
    ctx.lineTo(xScale(i), yScaleR(data[i].contestants || 0));
  }
  ctx.lineTo(xScale(data.length - 1), pad.top + ch);
  ctx.closePath();
  ctx.fillStyle = contestantColor + '18';
  ctx.fill();
  ctx.beginPath();
  ctx.strokeStyle = contestantColor;
  ctx.lineWidth = 2;
  for (var i = 0; i < data.length; i++) {
    var x = xScale(i);
    var y = yScaleR(data[i].contestants || 0);
    if (i === 0) ctx.moveTo(x, y);
    else ctx.lineTo(x, y);
  }
  ctx.stroke();
  for (var i = 0; i < data.length; i++) {
    ctx.fillStyle = contestantColor;
    ctx.beginPath();
    ctx.arc(xScale(i), yScaleR(data[i].contestants || 0), 2, 0, Math.PI * 2);
    ctx.fill();
  }

  drawXLabelsLine(ctx, CC, data, pad, cw, ch);

  setupTooltip(canvas, data, W, H, pad, ch, {
    getIdx: lineGetIdx(data, pad, cw),
    isHidden: function() { return false; },
    getHtml: function(d) {
      return '<b>IMO ' + d.year + '</b><br>'
        + tooltipRow(CC.line, 'Countries', d.countries)
        + tooltipRow(contestantColor, 'Contestants', d.contestants);
    }
  });
}
drawGrowthChart();
document.addEventListener('astro:page-load', drawGrowthChart);
</script>
