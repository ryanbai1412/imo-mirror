---
import Layout from "../layouts/Layout.astro";
import SubNav from "../components/SubNav.astro";
import { loadIndividualResultsByYear, loadYearInfo } from "../utils/data";
import { sortData, parseSortParams, getSortUrl, sortIndicator } from "../utils/sort";

const origin = Astro.url.origin;
const year = Astro.url.searchParams.get("year") || "";
if (!year) return Astro.redirect("/results.aspx");

const [individualResults, yearInfoMap] = await Promise.all([
  loadIndividualResultsByYear(origin),
  loadYearInfo(origin),
]);

const results = individualResults[year] || [];
const info = yearInfoMap[year];
const { column, order } = parseSortParams(Astro.url.searchParams);
const sorted = column ? sortData(results, column, order) : results;

const cols = [
  { key: "name", label: "Name" },
  { key: "country", label: "Country" },
  { key: "p1", label: "P1", align: "right" },
  { key: "p2", label: "P2", align: "right" },
  { key: "p3", label: "P3", align: "right" },
  { key: "p4", label: "P4", align: "right" },
  { key: "p5", label: "P5", align: "right" },
  { key: "p6", label: "P6", align: "right" },
  { key: "total", label: "Total", align: "right" },
  { key: "rank", label: "Rank", align: "right" },
  { key: "award", label: "Award" },
];
---

<Layout title={`IMO ${year} - Individual Results`} description={`Individual results for the ${year} International Mathematical Olympiad. Scores, rankings, and awards for all contestants.`} path={`/year_individual_r.aspx?year=${year}`}>
  <div class="page-content">
    <h2>IMO {year} &mdash; Individual Results</h2>
    <SubNav items={[
      { label: "Overview", href: `/year_info.aspx?year=${year}` },
      { label: "Country Results", href: `/year_country_r.aspx?year=${year}` },
      { label: "Individual Results", href: `/year_individual_r.aspx?year=${year}` },
      { label: "Statistics", href: `/year_statistics.aspx?year=${year}` },
    ]} currentPath={`/year_individual_r.aspx?year=${year}`} />

    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            {cols.map(col => (
              <th class:list={[col.align === "right" && "text-right", "sortable-header"]}>
                <a href={getSortUrl(Astro.url, col.key, column, order)}>{col.label}{sortIndicator(col.key, column, order)}</a>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {sorted.map((row, idx) => (
            <tr class={idx % 2 === 0 ? "even" : "odd"}>
              <td>{row.participant_id ? <a href={`/participant_r.aspx?id=${row.participant_id}`}>{row.name}</a> : row.name}</td>
              <td><a href={`/country_info.aspx?code=${row.country_code}`}>{row.country}</a></td>
              <td class="text-right">{row.p1 ?? ""}</td>
              <td class="text-right">{row.p2 ?? ""}</td>
              <td class="text-right">{row.p3 ?? ""}</td>
              <td class="text-right">{row.p4 ?? ""}</td>
              <td class="text-right">{row.p5 ?? ""}</td>
              <td class="text-right">{row.p6 ?? ""}</td>
              <td class="text-right">{row.total ?? ""}</td>
              <td class="text-right">{row.rank ?? ""}</td>
              <td><span class={`award-${(row.award || "").toLowerCase().replace(/\s+/g, "-")}`}>{row.award}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>
