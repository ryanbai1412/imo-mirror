---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { loadIndividualResultsByYear, loadYearInfo, loadTimeline } from "../utils/data";
import { sortData, parseSortParams, getSortUrl, sortIndicator } from "../utils/sort";
import CountryLink from "../components/CountryLink.astro";
import { CHART_COLORS, STACKED_BAR_ORDER } from "../utils/chartColors";
import { awardClass } from "../utils/awardClass";

const origin = Astro.url.origin;
const year = Astro.url.searchParams.get("year") || "";
if (!year) return Astro.redirect("/results.aspx");

const [individualResults, yearInfoMap, timeline] = await Promise.all([
  loadIndividualResultsByYear(origin),
  loadYearInfo(origin),
  loadTimeline(origin),
]);

const results = individualResults[year] || [];
const info = yearInfoMap[year];
const yearNum = Number(year);
const prevYear = timeline.find(t => t.year === yearNum - 1);
const nextYear = timeline.find(t => t.year === yearNum + 1);
const { column, order } = parseSortParams(Astro.url.searchParams);
const sorted = column ? sortData(results, column, order) : results;

const maxScore = 42;
const distBuckets: { score: number; gold: number; silver: number; bronze: number; hm: number; none: number }[] = [];
for (let s = 0; s <= maxScore; s++) {
  distBuckets.push({ score: s, gold: 0, silver: 0, bronze: 0, hm: 0, none: 0 });
}
for (const r of results) {
  if (r.total == null || r.total < 0 || r.total > maxScore) continue;
  const bucket = distBuckets[r.total];
  const award = (r.award || "").toLowerCase();
  if (award.includes("gold")) bucket.gold++;
  else if (award.includes("silver")) bucket.silver++;
  else if (award.includes("bronze")) bucket.bronze++;
  else if (award.includes("honourable") || award.includes("hm")) bucket.hm++;
  else bucket.none++;
}
const distChartData = JSON.stringify(distBuckets);
const chartColorsJson = JSON.stringify(CHART_COLORS);
const stackedBarOrderJson = JSON.stringify(STACKED_BAR_ORDER);

const cols = [
  { key: "name", label: "Name" },
  { key: "country", label: "Country" },
  { key: "p1", label: "P1", title: "Problem 1", align: "center", defaultOrder: "desc" as const },
  { key: "p2", label: "P2", title: "Problem 2", align: "center", defaultOrder: "desc" as const },
  { key: "p3", label: "P3", title: "Problem 3", align: "center", defaultOrder: "desc" as const },
  { key: "p4", label: "P4", title: "Problem 4", align: "center", defaultOrder: "desc" as const },
  { key: "p5", label: "P5", title: "Problem 5", align: "center", defaultOrder: "desc" as const },
  { key: "p6", label: "P6", title: "Problem 6", align: "center", defaultOrder: "desc" as const },
  { key: "total", label: "Total", align: "center", defaultOrder: "desc" as const },
  { key: "rank", label: "Rank", align: "center" },
  { key: "award", label: "Award" },
];
---

<Layout title={`IMO ${year} - Individual Results`} description={`Individual results for the ${year} International Mathematical Olympiad. Scores, rankings, and awards for all contestants.`} path={`/year_individual_r.aspx?year=${year}`}>
  <div class="page-content">
    <PageHeader title={`IMO ${year} — Individual Results`} navItems={[
      { label: "Overview", href: `/year_info.aspx?year=${year}` },
      { label: "Country Results", href: `/year_country_r.aspx?year=${year}` },
      { label: "Individual Results", href: `/year_individual_r.aspx?year=${year}` },
      { label: "Statistics", href: `/year_statistics.aspx?year=${year}` },
    ]} currentPath={`/year_individual_r.aspx?year=${year}`}
      prevHref={prevYear ? `/year_individual_r.aspx?year=${prevYear.year}` : undefined}
      nextHref={nextYear ? `/year_individual_r.aspx?year=${nextYear.year}` : undefined}
    />

    {results.length > 0 && (
      <div class="stats-section">
        <h3>Points Distribution</h3>
        <div class="chart-wrapper">
          <canvas id="dist-chart" width="700" height="320"></canvas>
        </div>
        <div class="chart-legend">
          <span class="legend-item"><span class="legend-swatch" style={`background:${CHART_COLORS.gold}`}></span>Gold medal</span>
          <span class="legend-item"><span class="legend-swatch" style={`background:${CHART_COLORS.silver}`}></span>Silver medal</span>
          <span class="legend-item"><span class="legend-swatch" style={`background:${CHART_COLORS.bronze}`}></span>Bronze medal</span>
          <span class="legend-item"><span class="legend-swatch" style={`background:${CHART_COLORS.hm}`}></span>Honourable mention</span>
          <span class="legend-item"><span class="legend-swatch" style={`background:${CHART_COLORS.none}`}></span>Nothing</span>
        </div>
      </div>
    )}

    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            {cols.map(col => (
              <th class:list={[col.align === "center" && "text-center", "sortable-header"]} title={col.title}>
                <a href={getSortUrl(Astro.url, col.key, column, order, col.defaultOrder)}>{col.label}{sortIndicator(col.key, column, order)}</a>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {sorted.map((row) => (
            <tr>
              <td>{row.participant_id ? <a href={`/participant_r.aspx?id=${row.participant_id}`}>{row.name}</a> : row.name}</td>
              <td><CountryLink code={row.country_code} label={row.country} /></td>
              <td class="text-center">{row.p1 ?? ""}</td>
              <td class="text-center">{row.p2 ?? ""}</td>
              <td class="text-center">{row.p3 ?? ""}</td>
              <td class="text-center">{row.p4 ?? ""}</td>
              <td class="text-center">{row.p5 ?? ""}</td>
              <td class="text-center">{row.p6 ?? ""}</td>
              <td class="text-center">{row.total ?? ""}</td>
              <td class="text-center">{row.rank ?? ""}</td>
              <td><span class={awardClass(row.award)}>{row.award}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script define:vars={{ distChartData, year, chartColorsJson, stackedBarOrderJson }}>
function drawYearDistChart() {
  const data = JSON.parse(distChartData);
  const canvas = document.getElementById('dist-chart');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  const W = 700, H = 320;
  canvas.width = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);

  const pad = { top: 30, right: 16, bottom: 36, left: 40 };
  const cw = W - pad.left - pad.right;
  const ch = H - pad.top - pad.bottom;

  const maxTotal = data.reduce((m, d) =>
    Math.max(m, d.gold + d.silver + d.bronze + d.hm + d.none), 0);
  const yMax = Math.ceil(maxTotal / 5) * 5 || 5;
  const barW = cw / data.length;
  const gap = Math.max(1, barW * 0.15);

  const CC = JSON.parse(chartColorsJson);
  const colors = JSON.parse(stackedBarOrderJson);

  ctx.fillStyle = CC.bg;
  ctx.fillRect(0, 0, W, H);

  ctx.strokeStyle = CC.grid;
  ctx.lineWidth = 0.5;
  ctx.font = '11px system-ui, sans-serif';
  ctx.fillStyle = CC.label;
  ctx.textAlign = 'right';
  const ticks = 5;
  for (let i = 0; i <= ticks; i++) {
    const v = Math.round(yMax * i / ticks);
    const y = pad.top + ch - (v / yMax) * ch;
    ctx.beginPath();
    ctx.moveTo(pad.left, y);
    ctx.lineTo(W - pad.right, y);
    ctx.stroke();
    ctx.fillText(String(v), pad.left - 6, y + 4);
  }

  for (let i = 0; i < data.length; i++) {
    const d = data[i];
    const x = pad.left + i * barW + gap / 2;
    const bw = barW - gap;
    let y = pad.top + ch;
    for (const c of colors) {
      const val = d[c.key];
      if (!val) continue;
      const h = (val / yMax) * ch;
      y -= h;
      ctx.fillStyle = c.color;
      ctx.fillRect(x, y, bw, h);
    }

    if (i % 5 === 0 || i === data.length - 1) {
      ctx.fillStyle = CC.label;
      ctx.textAlign = 'center';
      ctx.fillText(String(d.score),
        x + bw / 2, pad.top + ch + 16);
    }
  }

  ctx.fillStyle = CC.title;
  ctx.font = 'bold 13px system-ui, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('Points distribution - IMO ' + year,
    W / 2, pad.top - 10);

  const existing = canvas.parentElement.querySelector('.chart-tooltip');
  if (existing) existing.remove();
  const tip = document.createElement('div');
  tip.className = 'chart-tooltip';
  canvas.parentElement.appendChild(tip);
  let lastIdx = -1;
  canvas.addEventListener('mousemove', function(e) {
    const rect = canvas.getBoundingClientRect();
    const mx = (e.clientX - rect.left) * (W / rect.width);
    const my = (e.clientY - rect.top) * (H / rect.height);
    const idx = Math.floor((mx - pad.left) / barW);
    if (idx < 0 || idx >= data.length || my > pad.top + ch) {
      tip.classList.remove('visible'); lastIdx = -1; return;
    }
    const d0 = data[idx];
    const barTotal = d0.gold + d0.silver + d0.bronze + d0.hm + d0.none;
    const barTopY = pad.top + ch - (barTotal / yMax) * ch;
    if (my < barTopY) {
      tip.classList.remove('visible'); lastIdx = -1; return;
    }
    const ox = canvas.offsetLeft;
    const oy = canvas.offsetTop;
    const curX = e.clientX - rect.left;
    const wrapW = canvas.parentElement.offsetWidth;
    const tx = (ox + curX + 160 > wrapW) ? ox + curX - 12 : ox + curX + 12;
    const ty = oy + (e.clientY - rect.top) - 10;
    tip.style.transform = (ox + curX + 160 > wrapW) ? 'translateX(-100%)' : '';
    if (idx === lastIdx) {
      tip.style.left = tx + 'px';
      tip.style.top = ty + 'px';
      return;
    }
    lastIdx = idx;
    const d = data[idx];
    const total = d.gold + d.silver + d.bronze + d.hm + d.none;
    let html = '<b>Score ' + d.score + '</b> (' + total + ' contestants)<br>';
    if (d.gold) html += '<div class="chart-tooltip-row"><span class="chart-tooltip-swatch" style="background:' + CC.gold + '"></span>Gold: ' + d.gold + '</div>';
    if (d.silver) html += '<div class="chart-tooltip-row"><span class="chart-tooltip-swatch" style="background:' + CC.silver + '"></span>Silver: ' + d.silver + '</div>';
    if (d.bronze) html += '<div class="chart-tooltip-row"><span class="chart-tooltip-swatch" style="background:' + CC.bronze + '"></span>Bronze: ' + d.bronze + '</div>';
    if (d.hm) html += '<div class="chart-tooltip-row"><span class="chart-tooltip-swatch" style="background:' + CC.hm + '"></span>HM: ' + d.hm + '</div>';
    if (d.none) html += '<div class="chart-tooltip-row"><span class="chart-tooltip-swatch" style="background:' + CC.none + '"></span>None: ' + d.none + '</div>';
    tip.innerHTML = html;
    tip.classList.add('visible');
    tip.style.left = tx + 'px';
    tip.style.top = ty + 'px';
  });
  canvas.addEventListener('mouseleave', function() {
    tip.classList.remove('visible'); lastIdx = -1;
  });
}
drawYearDistChart();
document.addEventListener('astro:page-load', drawYearDistChart);
</script>
