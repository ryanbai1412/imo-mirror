---
interface Props {
  title: string;
  navItems: { label: string; href: string }[];
  currentPath: string;
  prevHref?: string;
  nextHref?: string;
}

const { title, navItems, currentPath, prevHref, nextHref } = Astro.props;
const hasSlot = Astro.slots.has("title");
const hasArrows = prevHref || nextHref;
---

<div class="page-header">
  {hasArrows ? (
    <div class="page-header-title year-arrows">
      {prevHref && <a href={prevHref} class="arrow-link">&larr;</a>}
      <h2>{hasSlot ? <slot name="title" /> : title}</h2>
      {nextHref && <a href={nextHref} class="arrow-link">&rarr;</a>}
    </div>
  ) : (
    <h2>{hasSlot ? <slot name="title" /> : title}</h2>
  )}
  <nav class="pill-nav">
    {navItems.map(item => (
      <a href={item.href} class={currentPath === item.href ? "active" : ""}>{item.label}</a>
    ))}
  </nav>
</div>

<style>
  .page-header {
    margin-bottom: 24px;
  }
  .page-header h2 {
    font-family: var(--font-display);
    font-size: 28px; font-weight: 400; color: var(--navy);
    letter-spacing: -0.01em; line-height: 1.2;
    margin: 0 0 20px;
  }
  .page-header-title.year-arrows {
    display: inline-flex; align-items: center; gap: 14px;
    margin-bottom: 20px;
  }
  .page-header-title.year-arrows h2 {
    margin-bottom: 0;
  }
  .arrow-link {
    font-size: 22px; font-weight: 400;
    color: var(--text-muted);
    transition: color var(--transition);
  }
  .arrow-link:hover { color: var(--navy); }
</style>
