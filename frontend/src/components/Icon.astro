---
import * as icons from "lucide-static";
import { resizeSvg } from "../utils/svgResize";

interface Props {
  name: keyof typeof icons;
  size?: number;
  class?: string;
}

const { name, size = 18, class: className } = Astro.props;
const raw = icons[name] as string;
const svg = resizeSvg(raw, size);
---
<Fragment set:html={className ? svg.replace('<svg', `<svg class="${className}"`) : svg} />
