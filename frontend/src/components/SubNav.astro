---
interface Props {
  items: { label: string; href: string }[];
  currentPath: string;
}

const { items, currentPath } = Astro.props;
---

<nav class="pill-nav sub-nav">
  {items.map(item => (
    <a href={item.href} class={currentPath === item.href ? "active" : ""}>{item.label}</a>
  ))}
</nav>

<style>
  .sub-nav { margin: -8px 0 24px; }
</style>
