{
  "name": "imo-mirror",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "prebuild": "node scripts/generate_sitemap.mjs",
    "build": "vite build",
    "sitemap": "node scripts/generate_sitemap.mjs",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write 'src/**/*.{svelte,ts,js,css,html}' '*.config.{js,ts}'",
    "lint": "eslint 'src/**/*.{ts,svelte}'",
    "lint:fix": "eslint --fix 'src/**/*.{ts,svelte}'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.6.2",
    "cheerio": "^1.2.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11"
  },
  "dependencies": {
    "lucide-static": "^1.14.0"
  },
  "lint-staged": {
    "*.{svelte,ts,js,css,html}": "prettier --write",
    "*.{ts,svelte}": "eslint --fix"
  }
}
