---
import Layout from "../layouts/Layout.astro";
import { loadParticipants, loadIndividualResultsByYear, loadTimeline } from "../utils/data";
import CountryLink from "../components/CountryLink.astro";
import { CHART_COLORS, STACKED_BAR_ORDER } from "../utils/chartColors";
import ChartLegend from "../components/ChartLegend.astro";
import { awardType } from "../utils/awardClass";
import AwardLabel from "../components/AwardLabel.astro";

const origin = Astro.url.origin;
const id = Astro.url.searchParams.get("id") || "";
if (!id) return Astro.redirect("/");

const [participants, individualResults, timeline] = await Promise.all([
  loadParticipants(origin),
  loadIndividualResultsByYear(origin),
  loadTimeline(origin),
]);
const participant = participants[id];
if (!participant) return Astro.redirect("/");

const p = participant;
const totalGold = p.results.filter(r => awardType(r.award) === "gold").length;
const totalSilver = p.results.filter(r => awardType(r.award) === "silver").length;
const totalBronze = p.results.filter(r => awardType(r.award) === "bronze").length;
const totalHM = p.results.filter(r => awardType(r.award) === "hm").length;

const perfectScores = p.results.filter(r => r.total === 42).length;
const specialPrizes = p.results.filter(r => r.award.includes("Special prize")).length;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: p.name,
  description: `IMO participant with ${p.results.length} participation(s). ${totalGold} gold, ${totalSilver} silver, ${totalBronze} bronze medals.`,
};

const timelineByYear = new Map(timeline.map(t => [t.year, t]));
const participantYears = new Set(p.results.map(r => r.year));
const rankChartData: { year: number; edition: number; gold: number; silver: number; bronze: number; hm: number; none: number; rank: number | null }[] = [];
for (const [yearStr, results] of Object.entries(individualResults)) {
  const yr = Number(yearStr);
  const tl = timelineByYear.get(yr);
  if (!tl) continue;
  let gold = 0, silver = 0, bronze = 0, hm = 0, none = 0;
  for (const r of results) {
    const t = awardType(r.award);
    if (t === "gold") gold++;
    else if (t === "silver") silver++;
    else if (t === "bronze") bronze++;
    else if (t === "hm") hm++;
    else none++;
  }
  const pResult = participantYears.has(yr) ? p.results.find(r => r.year === yr) : null;
  rankChartData.push({ year: yr, edition: tl.edition, gold, silver, bronze, hm, none, rank: pResult?.rank ?? null });
}
rankChartData.sort((a, b) => a.edition - b.edition);
const hasP7 = p.results.some(r => r.p7 != null);

const rankChartJson = JSON.stringify(rankChartData);
const chartColorsJson = JSON.stringify(CHART_COLORS);
const stackedBarOrderJson = JSON.stringify(STACKED_BAR_ORDER);
---

<Layout title={p.name} description={`${p.name} - IMO participant. ${p.results.length} participation(s), ${totalGold} gold, ${totalSilver} silver, ${totalBronze} bronze medals.`} path={`/participant_r.aspx?id=${id}`} jsonLd={jsonLd}>
  <div class="page-content">
    <div class="participant-header">
      <h2>{p.name}</h2>
      <div class="stats-row">
        {specialPrizes > 0 && (
          <div class="stat-card">
            <span class="stat-value">{specialPrizes}</span>
            <span class="stat-label">Special Prize{specialPrizes !== 1 ? "s" : ""}</span>
          </div>
        )}
        {perfectScores > 0 && (
          <div class="stat-card">
            <span class="stat-value">{perfectScores}</span>
            <span class="stat-label">Perfect Score{perfectScores !== 1 ? "s" : ""}</span>
          </div>
        )}
        {totalGold > 0 && (
          <div class="stat-card">
            <span class="stat-value award-gold-medal">{totalGold}</span>
            <span class="stat-label">Gold</span>
          </div>
        )}
        {totalSilver > 0 && (
          <div class="stat-card">
            <span class="stat-value award-silver-medal">{totalSilver}</span>
            <span class="stat-label">Silver</span>
          </div>
        )}
        {totalBronze > 0 && (
          <div class="stat-card">
            <span class="stat-value award-bronze-medal">{totalBronze}</span>
            <span class="stat-label">Bronze</span>
          </div>
        )}
        {totalHM > 0 && (
          <div class="stat-card">
            <span class="stat-value award-honourable-mention">{totalHM}</span>
            <span class="stat-label">HM</span>
          </div>
        )}
        <div class="stat-card">
          <span class="stat-value">{p.results.length}</span>
          <span class="stat-label">Participation{p.results.length !== 1 ? "s" : ""}</span>
        </div>
      </div>
    </div>

    {rankChartData.length > 1 && (
      <div class="stats-section">
        <h3>Individual Ranking</h3>
        <div class="chart-wrapper">
          <canvas id="rank-chart" width="700" height="320"></canvas>
        </div>
        <ChartLegend items={[
          { color: CHART_COLORS.gold, label: "Gold medal" },
          { color: CHART_COLORS.silver, label: "Silver medal" },
          { color: CHART_COLORS.bronze, label: "Bronze medal" },
          { color: CHART_COLORS.none, label: "No medal" },
        ]} />
      </div>
    )}

    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th class="text-center">Year</th>
            <th>Country</th>
            <th class="text-center" title="Problem 1">P1</th>
            <th class="text-center" title="Problem 2">P2</th>
            <th class="text-center" title="Problem 3">P3</th>
            <th class="text-center" title="Problem 4">P4</th>
            <th class="text-center" title="Problem 5">P5</th>
            <th class="text-center" title="Problem 6">P6</th>
            {hasP7 && <th class="text-center" title="Problem 7">P7</th>}
            <th class="text-center">Total</th>
            <th class="text-center">Rank</th>
            <th>Award</th>
          </tr>
        </thead>
        <tbody>
          {[...p.results].sort((a, b) => b.year - a.year).map((r) => (
            <tr>
              <td class="text-center"><a href={`/year_info.aspx?year=${r.year}`}>{r.year}</a></td>
              <td><CountryLink code={r.country_code} label={r.country} year={r.year} /></td>
              <td class="text-center">{r.p1 ?? ""}</td>
              <td class="text-center">{r.p2 ?? ""}</td>
              <td class="text-center">{r.p3 ?? ""}</td>
              <td class="text-center">{r.p4 ?? ""}</td>
              <td class="text-center">{r.p5 ?? ""}</td>
              <td class="text-center">{r.p6 ?? ""}</td>
              {hasP7 && <td class="text-center">{r.p7 ?? ""}</td>}
              <td class="text-center">{r.total ?? ""}</td>
              <td class="text-center">{r.rank ?? ""}</td>
              <td><AwardLabel award={r.award} /></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ rankChartJson, chartColorsJson, stackedBarOrderJson }}>
var CC = JSON.parse(chartColorsJson);
var colors = JSON.parse(stackedBarOrderJson);
function drawIndividualRankChart() {
  var data = JSON.parse(rankChartJson);
  var r = drawMedalStackedChart('rank-chart', data, CC, colors, {
    yStep: 50, pad: { top: 30, right: 16, bottom: 36, left: 40 },
    sumFn: medalTotal,
    getHtml: function(d) {
      var total = medalTotal(d);
      var html = '<b>IMO ' + d.year + '</b> (' + total + ' contestants)<br>';
      if (d.rank != null) html += rankLabel(d.rank) + ' / ' + total + '<br>';
      html += tooltipRow(CC.gold, 'Gold', d.gold) + tooltipRow(CC.silver, 'Silver', d.silver)
        + tooltipRow(CC.bronze, 'Bronze', d.bronze) + tooltipRow(CC.none, 'None', d.none);
      return html;
    }
  });
  if (!r) return;
  drawRankOverlay(r.ctx, CC, data, r.pad, r.ch, r.barW, r.gap, r.yMax, 'rank', medalTotal);
  drawTitle(r.ctx, CC, 'Individual ranking', r.W, r.pad);
}
drawIndividualRankChart();
document.addEventListener('astro:page-load', drawIndividualRankChart);
</script>

<style>
  .participant-header { margin-bottom: 24px; }
</style>
