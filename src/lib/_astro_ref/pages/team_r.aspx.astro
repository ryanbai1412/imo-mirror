---
import Layout from "../layouts/Layout.astro";
import {
  loadIndividualResultsByYear,
  loadCountryResultsByYear,
  loadCountries,
  loadTimeline,
  buildDistBuckets,
} from "../utils/data";
import { CHART_COLORS, STACKED_BAR_ORDER } from "../utils/chartColors";
import ChartLegend from "../components/ChartLegend.astro";
import AwardLabel from "../components/AwardLabel.astro";

const origin = Astro.url.origin;
const code = Astro.url.searchParams.get("code") || "";
const year = Astro.url.searchParams.get("year") || "";

if (!code && !year) return Astro.redirect("/results_country.aspx");
if (!year) return Astro.redirect(`/country_team_r.aspx?code=${code}`);
if (!code) return Astro.redirect(`/year_country_r.aspx?year=${year}`);

const [individualResults, countryResults, countries, timeline] = await Promise.all([
  loadIndividualResultsByYear(origin),
  loadCountryResultsByYear(origin),
  loadCountries(origin),
  loadTimeline(origin),
]);

const country = countries.find(c => c.code === code);
const yearNum = Number(year);
const allIndividual = individualResults[year] || [];
const teamMembers = allIndividual.filter(r => r.country_code === code);
teamMembers.sort((a, b) => (b.total ?? 0) - (a.total ?? 0));

const countryYearResults = countryResults[year] || [];
const teamResult = countryYearResults.find(r => r.code === code);

const sortedYears = timeline.map(t => t.year).sort((a, b) => a - b);
const prevYear = timeline.find(t => t.year === sortedYears.filter(y => y < yearNum).pop());
const nextYear = timeline.find(t => t.year === sortedYears.find(y => y > yearNum));
const prevHasTeam = prevYear && (countryResults[String(prevYear.year)] || []).some(r => r.code === code);
const nextHasTeam = nextYear && (countryResults[String(nextYear.year)] || []).some(r => r.code === code);

const distBuckets = allIndividual.length > 0 ? buildDistBuckets(allIndividual) : [];
const distChartData = JSON.stringify(distBuckets);
const chartColorsJson = JSON.stringify(CHART_COLORS);
const stackedBarOrderJson = JSON.stringify(STACKED_BAR_ORDER);
const teamCodes = JSON.stringify(teamMembers.map(m => m.total ?? -1));

const hasP7 = teamMembers.some(m => m.p7 != null) || (teamResult?.p7 != null);

const teamTotal = teamMembers.reduce((s, m) => s + (m.total ?? 0), 0);

const binSize = 10;
const maxPossible = 252;
const numBins = Math.ceil(maxPossible / binSize) + 1;
const countryBins: number[] = Array(numBins).fill(0);
const binRanks: { min: number; max: number }[] = Array.from({ length: numBins }, () => ({ min: Infinity, max: -Infinity }));
for (const r of countryYearResults) {
  if (r.total == null) continue;
  const bin = Math.min(Math.floor(r.total / binSize), numBins - 1);
  countryBins[bin]++;
  if (r.rank != null) {
    binRanks[bin].min = Math.min(binRanks[bin].min, r.rank);
    binRanks[bin].max = Math.max(binRanks[bin].max, r.rank);
  }
}
const countryDistData = countryBins.map((count, i) => ({
  label: `${i * binSize}\u2013${i * binSize + binSize - 1}`,
  lo: i * binSize,
  count,
  rankMin: binRanks[i].min === Infinity ? null : binRanks[i].min,
  rankMax: binRanks[i].max === -Infinity ? null : binRanks[i].max,
}));
const countryDistJson = JSON.stringify(countryDistData);
const teamBin = teamTotal != null ? Math.min(Math.floor(teamTotal / binSize), numBins - 1) : -1;
---

<Layout
  title={`${country?.name || code} at IMO ${year}`}
  description={`Results for ${country?.name || code} at the ${year} International Mathematical Olympiad. Individual scores, rankings, and awards.`}
  path={`/team_r.aspx?code=${code}&year=${year}`}
>
  <div class="page-content">
    <div class="team-header">
      <h2 class="team-header-country">
        <a href={`/country_info.aspx?code=${code}`}>
          {country?.flag_url && <img src={country.flag_url} alt={code} class="country-flag-large" />}
          {country?.name || code}
        </a>
      </h2>
      <div class="team-header-year">
        {prevHasTeam && <a href={`/team_r.aspx?code=${code}&year=${prevYear!.year}`} class="arrow-link">&larr;</a>}
        <h3><a href={`/year_info.aspx?year=${year}`}>IMO {year}</a></h3>
        {nextHasTeam && <a href={`/team_r.aspx?code=${code}&year=${nextYear!.year}`} class="arrow-link">&rarr;</a>}
      </div>
    </div>

    {teamResult && (teamResult.leader || teamResult.deputy_leader) && (
      <div class="team-leaders">
        {teamResult.leader && <p><strong>Leader:</strong> {teamResult.leader}</p>}
        {teamResult.deputy_leader && <p><strong>Deputy leader:</strong> {teamResult.deputy_leader}</p>}
      </div>
    )}

    {teamResult && (
      <div class="stats-row">
        {!!teamResult.rank && (
          <div class="stat-card">
            <span class="stat-value">{teamResult.rank}</span>
            <span class="stat-label">Rank</span>
          </div>
        )}
        <div class="stat-card">
          <span class="stat-value">{teamTotal}</span>
          <span class="stat-label">Total Score</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">{teamMembers.length}</span>
          <span class="stat-label">Contestants</span>
        </div>
        {(teamResult.awards_gold ?? 0) > 0 && (
          <div class="stat-card">
            <span class="stat-value award-gold-medal">{teamResult.awards_gold}</span>
            <span class="stat-label">Gold</span>
          </div>
        )}
        {(teamResult.awards_silver ?? 0) > 0 && (
          <div class="stat-card">
            <span class="stat-value award-silver-medal">{teamResult.awards_silver}</span>
            <span class="stat-label">Silver</span>
          </div>
        )}
        {(teamResult.awards_bronze ?? 0) > 0 && (
          <div class="stat-card">
            <span class="stat-value award-bronze-medal">{teamResult.awards_bronze}</span>
            <span class="stat-label">Bronze</span>
          </div>
        )}
        {(teamResult.awards_hm ?? 0) > 0 && (
          <div class="stat-card">
            <span class="stat-value award-honourable-mention">{teamResult.awards_hm}</span>
            <span class="stat-label">HM</span>
          </div>
        )}
      </div>
    )}

    {allIndividual.length > 0 && (
      <div class="charts-row">
        <div class="stats-section">
          <h3>Score Distribution</h3>
          <div class="chart-wrapper">
            <canvas id="dist-chart" width="700" height="320"></canvas>
          </div>
          <ChartLegend items={[
            { color: CHART_COLORS.gold, label: "Gold medal" },
            { color: CHART_COLORS.silver, label: "Silver medal" },
            { color: CHART_COLORS.bronze, label: "Bronze medal" },
            { color: CHART_COLORS.hm, label: "Honourable mention" },
            { color: CHART_COLORS.none, label: "Nothing" },
            { color: CHART_COLORS.line, label: `${country?.name || code} contestants`, line: true },
          ]} />
        </div>
        {countryYearResults.length > 0 && (
          <div class="stats-section">
            <h3>Country Score Distribution</h3>
            <div class="chart-wrapper">
              <canvas id="country-rank-chart" width="700" height="320"></canvas>
            </div>
            <ChartLegend items={[
              { color: CHART_COLORS.gold, label: `${country?.name || code}` },
              { color: CHART_COLORS.line, label: "Other countries" },
            ]} />
          </div>
        )}
      </div>
    )}

    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th>Contestant</th>
            <th class="text-center" title="Problem 1">P1</th>
            <th class="text-center" title="Problem 2">P2</th>
            <th class="text-center" title="Problem 3">P3</th>
            <th class="text-center" title="Problem 4">P4</th>
            <th class="text-center" title="Problem 5">P5</th>
            <th class="text-center" title="Problem 6">P6</th>
            {hasP7 && <th class="text-center" title="Problem 7">P7</th>}
            <th class="text-center">Total</th>
            <th class="text-center">Rank</th>
            <th>Award</th>
          </tr>
        </thead>
        <tbody>
          {teamMembers.map((m) => (
            <tr>
              <td>{m.participant_id ? <a href={`/participant_r.aspx?id=${m.participant_id}`}>{m.name}</a> : m.name}</td>
              <td class="text-center">{m.p1 ?? ""}</td>
              <td class="text-center">{m.p2 ?? ""}</td>
              <td class="text-center">{m.p3 ?? ""}</td>
              <td class="text-center">{m.p4 ?? ""}</td>
              <td class="text-center">{m.p5 ?? ""}</td>
              <td class="text-center">{m.p6 ?? ""}</td>
              {hasP7 && <td class="text-center">{m.p7 ?? ""}</td>}
              <td class="text-center">{m.total ?? ""}</td>
              <td class="text-center">{m.rank ?? ""}</td>
              <td><AwardLabel award={m.award} /></td>
            </tr>
          ))}
          {teamResult && (
            <tr class="table-summary-row">
              <td><strong>Team results</strong></td>
              <td class="text-center"><strong>{teamResult.p1 ?? ""}</strong></td>
              <td class="text-center"><strong>{teamResult.p2 ?? ""}</strong></td>
              <td class="text-center"><strong>{teamResult.p3 ?? ""}</strong></td>
              <td class="text-center"><strong>{teamResult.p4 ?? ""}</strong></td>
              <td class="text-center"><strong>{teamResult.p5 ?? ""}</strong></td>
              <td class="text-center"><strong>{teamResult.p6 ?? ""}</strong></td>
              {hasP7 && <td class="text-center"><strong>{teamResult.p7 ?? ""}</strong></td>}
              <td class="text-center"><strong>{teamTotal}</strong></td>
              <td class="text-center"><strong>{teamResult.rank ?? ""}</strong></td>
              <td></td>
            </tr>
          )}
        </tbody>
      </table>
    </div>

  </div>
</Layout>

<script is:inline define:vars={{ distChartData, year, code, chartColorsJson, stackedBarOrderJson, teamCodes, countryDistJson, teamBin }}>
var CC = JSON.parse(chartColorsJson);
var colors = JSON.parse(stackedBarOrderJson);
var teamScores = JSON.parse(teamCodes);
function drawTeamDistChart() {
  var data = JSON.parse(distChartData);
  var title = code + ' at IMO ' + year + ' \u2014 Score distribution';
  drawDistChart('dist-chart', data, colors, CC, title);
  // Draw dots for team member scores
  var canvas = document.getElementById('dist-chart');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var H = 320;
  var pad = { top: 30, right: 16, bottom: 36, left: 40 };
  var W = parseInt(canvas.style.width, 10) || 700;
  var cw = W - pad.left - pad.right;
  var ch = H - pad.top - pad.bottom;
  var barW = cw / data.length;
  var gap = Math.max(1, barW * 0.15);
  var dotR = 3.5;
  // Count occurrences per score bucket
  var counts = {};
  for (var ti = 0; ti < teamScores.length; ti++) {
    var s = teamScores[ti];
    if (s < 0 || s >= data.length) continue;
    counts[s] = (counts[s] || 0) + 1;
  }
  for (var score in counts) {
    var n = counts[score];
    var idx = Number(score);
    var cx = pad.left + idx * barW + barW / 2;
    for (var di = 0; di < n; di++) {
      var dy = pad.top + ch - dotR - 1 - di * (dotR * 2 + 2);
      ctx.fillStyle = CC.line;
      ctx.beginPath();
      ctx.arc(cx, dy, dotR, 0, Math.PI * 2);
      ctx.fill();
      ctx.fillStyle = CC.bg;
      ctx.beginPath();
      ctx.arc(cx, dy, 1.5, 0, Math.PI * 2);
      ctx.fill();
    }
  }
}
function drawCountryRankChart() {
  var data = JSON.parse(countryDistJson);
  var pad = { top: 30, right: 16, bottom: 48, left: 40 };
  var c = chartSetup('country-rank-chart', CC, 0, 320, pad);
  if (!c) return;
  var ctx = c.ctx, canvas = c.canvas, cw = c.cw, ch = c.ch, W = c.W, H = c.H;
  var last = data.findLastIndex(function(d) { return d.count > 0; });
  var visible = data.slice(0, Math.max(last + 2, 10));
  var maxCount = visible.reduce(function(m, d) { return Math.max(m, d.count); }, 0);
  var yMax = Math.ceil(maxCount / 5) * 5 || 5;
  var barW = cw / visible.length;
  var gap = Math.max(1, barW * 0.15);
  drawYGrid(ctx, CC, pad, W, ch, yMax);
  for (var i = 0; i < visible.length; i++) {
    var d = visible[i];
    var x = pad.left + i * barW + gap / 2;
    var bw = barW - gap;
    if (d.count > 0) {
      var h = (d.count / yMax) * ch;
      if (i === teamBin && d.count > 1) {
        var hOne = (1 / yMax) * ch;
        ctx.fillStyle = CC.line;
        ctx.fillRect(x, pad.top + ch - h, bw, h - hOne);
        ctx.fillStyle = CC.gold;
        ctx.fillRect(x, pad.top + ch - hOne, bw, hOne);
      } else {
        ctx.fillStyle = (i === teamBin) ? CC.gold : CC.line;
        ctx.fillRect(x, pad.top + ch - h, bw, h);
      }
    }
    ctx.fillStyle = CC.label;
    ctx.textAlign = 'center';
    ctx.font = '10px system-ui, sans-serif';
    ctx.fillText(String(d.lo), x + bw / 2, pad.top + ch + 14);
  }
  drawTitle(ctx, CC, 'Country total score \u2014 IMO ' + year, W, pad);
  ctx.font = '11px system-ui, sans-serif';
  ctx.fillStyle = CC.label;
  ctx.fillText('Total Score', W / 2, H - 4);
  setupTooltip(canvas, visible, W, H, pad, ch, {
    getIdx: barGetIdx(pad, barW),
    isHidden: function(my, idx) {
      var d0 = visible[idx];
      if (!d0.count) return true;
      return my < pad.top + ch - (d0.count / yMax) * ch;
    },
    getHtml: function(d) {
      var html = '<b>' + d.label + ' pts</b><br>' + d.count + (d.count === 1 ? ' country' : ' countries');
      var rl = rankLabel(d.rankMin, d.rankMax);
      if (rl) html += '<br>' + rl;
      return html;
    }
  });
}
drawTeamDistChart();
drawCountryRankChart();
document.addEventListener('astro:page-load', function() {
  drawTeamDistChart();
  drawCountryRankChart();
});
</script>

<style>
  .team-header {
    margin-bottom: 16px;
  }
  .team-header-country {
    margin: 0 0 4px;
  }
  .team-header-country a {
    color: var(--text);
    text-decoration: none;
  }
  .team-header-country a:hover {
    color: var(--link);
  }
  .team-header-year {
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .team-header-year h3 {
    margin: 0;
    font-size: 1.5rem;
  }
  .team-header-year a:not(.arrow-link) {
    color: var(--text-secondary);
    text-decoration: none;
  }
  .team-header-year a:not(.arrow-link):hover {
    color: var(--link);
  }
  .team-leaders {
    margin-bottom: 16px;
    font-size: 0.95rem;
  }
  .team-leaders p {
    margin: 0.25rem 0;
  }
  .table-summary-row {
    border-top: 2px solid var(--border);
    background: var(--icon-bg);
  }
</style>
