---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { loadResultsYear } from "../utils/data";
import { sortData, parseSortParams } from "../utils/sort";
import { CHART_COLORS } from "../utils/chartColors";
import { resultsNavItems } from "../utils/nav";
import ChartLegend from "../components/ChartLegend.astro";
import SortableTableHead from "../components/SortableTableHead.astro";

const origin = Astro.url.origin;
const yearData = await loadResultsYear(origin);
const { column, order } = parseSortParams(Astro.url.searchParams);
const sorted = column ? sortData(yearData, column, order) : yearData;

const chronoYear = [...yearData]
  .filter(r => r.year && r.gold != null)
  .sort((a, b) => a.year - b.year);
const medalChartData = JSON.stringify(chronoYear.map(r => ({
  year: r.year,
  gold: r.gold ?? 0,
  silver: r.silver ?? 0,
  bronze: r.bronze ?? 0,
  hm: r.hm ?? 0,
})));
const cutoffChartData = JSON.stringify(
  chronoYear
    .filter(r => r.gold_cutoff != null)
    .map(r => ({
      year: r.year,
      gold: r.gold_cutoff,
      silver: r.silver_cutoff,
      bronze: r.bronze_cutoff,
    }))
);
const chartColorsJson = JSON.stringify(CHART_COLORS);

const cols = [
  { key: "year", label: "Year", align: "center" },
  { key: "host_country", label: "Host" },
  { key: "num_countries", label: "Countries", align: "center", defaultOrder: "desc" as const },
  { key: "contestants_all", label: "Cont.", title: "Contestants", align: "center", defaultOrder: "desc" as const },
  { key: "contestants_male", label: "Male", title: "Male contestants", align: "center", defaultOrder: "desc" as const },
  { key: "contestants_female", label: "Female", title: "Female contestants", align: "center", defaultOrder: "desc" as const },
  { key: "gold", label: "G", title: "Gold medals", align: "center", defaultOrder: "desc" as const },
  { key: "silver", label: "S", title: "Silver medals", align: "center", defaultOrder: "desc" as const },
  { key: "bronze", label: "B", title: "Bronze medals", align: "center", defaultOrder: "desc" as const },
  { key: "hm", label: "HM", title: "Honourable Mention", align: "center", defaultOrder: "desc" as const },
  { key: "gold_cutoff", label: "G\u2265", title: "Gold cutoff score", align: "center", defaultOrder: "desc" as const },
  { key: "silver_cutoff", label: "S\u2265", title: "Silver cutoff score", align: "center", defaultOrder: "desc" as const },
  { key: "bronze_cutoff", label: "B\u2265", title: "Bronze cutoff score", align: "center", defaultOrder: "desc" as const },
];
---

<Layout title="Results by Year" description="IMO results by year. Medal counts, cutoff scores, host countries, and participation statistics for every International Mathematical Olympiad." path="/results_year.aspx">
  <div class="page-content">
    <PageHeader title="Results by Year" navItems={resultsNavItems} currentPath="/results_year.aspx" />

    <div class="charts-row">
      <div class="stats-section">
        <h3>Medal Counts Over Time</h3>
        <div class="chart-wrapper">
          <canvas id="medal-time-chart" width="700" height="320"></canvas>
        </div>
        <ChartLegend items={[
          { color: CHART_COLORS.gold, label: "Gold" },
          { color: CHART_COLORS.silver, label: "Silver" },
          { color: CHART_COLORS.bronze, label: "Bronze" },
          { color: CHART_COLORS.hm, label: "HM" },
        ]} />
      </div>
      <div class="stats-section">
        <h3>Cutoff Scores Over Time</h3>
        <div class="chart-wrapper">
          <canvas id="cutoff-time-chart" width="700" height="320"></canvas>
        </div>
        <ChartLegend items={[
          { color: CHART_COLORS.gold, label: "Gold cutoff", line: true },
          { color: CHART_COLORS.silver, label: "Silver cutoff", line: true },
          { color: CHART_COLORS.bronze, label: "Bronze cutoff", line: true },
        ]} />
      </div>
    </div>

    <div class="table-container">
      <table class="data-table">
        <SortableTableHead cols={cols} url={Astro.url} column={column} order={order} />
        <tbody>
          {sorted.map((row) => (
            <tr>
              <td class="text-center"><a href={`/year_info.aspx?year=${row.year}`}>{row.year}</a></td>
              <td>{row.host_country}</td>
              <td class="text-center">{row.num_countries ?? ""}</td>
              <td class="text-center">{row.contestants_all ?? ""}</td>
              <td class="text-center">{row.contestants_male ?? ""}</td>
              <td class="text-center">{row.contestants_female ?? ""}</td>
              <td class="text-center">{row.gold}</td>
              <td class="text-center">{row.silver}</td>
              <td class="text-center">{row.bronze}</td>
              <td class="text-center">{row.hm}</td>
              <td class="text-center">{row.gold_cutoff ?? ""}</td>
              <td class="text-center">{row.silver_cutoff ?? ""}</td>
              <td class="text-center">{row.bronze_cutoff ?? ""}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ medalChartData, cutoffChartData, chartColorsJson }}>
var CC = JSON.parse(chartColorsJson);
function drawMedalTimeChart() {
  var data = JSON.parse(medalChartData);
  var layers = [
    { key: 'gold', color: CC.gold }, { key: 'silver', color: CC.silver },
    { key: 'bronze', color: CC.bronze }, { key: 'hm', color: CC.hm },
  ];
  drawMedalStackedChart('medal-time-chart', data, CC, layers, { yStep: 50, minGap: 0.5 });
}
function drawCutoffTimeChart() {
  var data = JSON.parse(cutoffChartData);
  var pad = { top: 20, right: 16, bottom: 36, left: 40 };
  var c = chartSetup('cutoff-time-chart', CC, 0, 320, pad);
  if (!c || !data.length) return;
  var ctx = c.ctx, canvas = c.canvas, cw = c.cw, ch = c.ch, W = c.W, H = c.H;
  var allVals = data.flatMap(function(d) { return [d.gold, d.silver, d.bronze].filter(function(v) { return v != null; }); });
  var yMax = Math.ceil(Math.max.apply(null, allVals) / 5) * 5 || 42;
  var lines = [
    { key: 'gold', color: CC.gold }, { key: 'silver', color: CC.silver }, { key: 'bronze', color: CC.bronze },
  ];
  drawYGrid(ctx, CC, pad, W, ch, yMax);
  drawMultiLine(ctx, data, pad, cw, ch, yMax, lines);
  drawXLabelsLine(ctx, CC, data, pad, cw, ch);
  var yScale = function(v) { return pad.top + ch - (v / yMax) * ch; };
  setupTooltip(canvas, data, W, H, pad, ch, {
    getIdx: lineGetIdx(data, pad, cw),
    isHidden: function(my, idx) {
      var d = data[idx];
      var topVal = Math.max(d.gold || 0, d.silver || 0, d.bronze || 0);
      return topVal && my < yScale(topVal);
    },
    getHtml: function(d) {
      var html = '<b>IMO ' + d.year + '</b><br>';
      if (d.gold != null) html += tooltipRow(CC.gold, 'Gold cutoff', d.gold);
      if (d.silver != null) html += tooltipRow(CC.silver, 'Silver cutoff', d.silver);
      if (d.bronze != null) html += tooltipRow(CC.bronze, 'Bronze cutoff', d.bronze);
      return html;
    }
  });
}
drawMedalTimeChart();
drawCutoffTimeChart();
document.addEventListener('astro:page-load', function() {
  if (document.getElementById('medal-time-chart')) drawMedalTimeChart();
  if (document.getElementById('cutoff-time-chart')) drawCutoffTimeChart();
});
</script>
