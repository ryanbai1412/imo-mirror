---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { loadYearInfo, loadTimeline, formatDate } from "../utils/data";
import { yearNavItems } from "../utils/nav";

const origin = Astro.url.origin;
const year = Astro.url.searchParams.get("year") || "";
if (!year) return Astro.redirect("/organizers.aspx");

const [yearInfoMap, timeline] = await Promise.all([
  loadYearInfo(origin),
  loadTimeline(origin),
]);

const info = yearInfoMap[year];
const entry = timeline.find(t => t.year === Number(year));
if (!info && !entry) return Astro.redirect("/organizers.aspx");

const yearNum = Number(year);
const sortedYears = timeline.map(t => t.year).sort((a, b) => a - b);
const prevYear = timeline.find(t => t.year === sortedYears.filter(y => y < yearNum).pop());
const nextYear = timeline.find(t => t.year === sortedYears.find(y => y > yearNum));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Event",
  name: `International Mathematical Olympiad ${year}`,
  startDate: entry?.date || year,
  location: entry ? { "@type": "Place", name: `${entry.city}, ${entry.country}` } : undefined,
};
---

<Layout title={`IMO ${year}`} description={`IMO ${year} held in ${entry?.city || ""}, ${entry?.country || ""}. ${info?.num_contestants || ""} contestants from ${info?.num_countries || ""} countries.`} path={`/year_info.aspx?year=${year}`} jsonLd={jsonLd}>
  <div class="page-content">
    <PageHeader title={`IMO ${year}`} navItems={yearNavItems(year)} currentPath={`/year_info.aspx?year=${year}`}
      prevHref={prevYear ? `/year_info.aspx?year=${prevYear.year}` : undefined}
      nextHref={nextYear ? `/year_info.aspx?year=${nextYear.year}` : undefined}
    />

    {entry && (
      <div class="info-grid-group">
        <h3>General Information</h3>
        <div class="info-grid">
          <span class="info-label">Edition</span><span class="info-value">{entry.edition}</span>
          <span class="info-label">Location</span><span class="info-value">{entry.city}, {entry.country}</span>
          <span class="info-label">Date</span><span class="info-value">{formatDate(entry.date)}</span>
          {info?.num_countries && <><span class="info-label">Countries</span><span class="info-value">{info.num_countries}</span></>}
          {info?.num_contestants && <><span class="info-label">Contestants</span><span class="info-value">{info.num_contestants}</span></>}
          {info?.homepage && <><span class="info-label">Homepage</span><span class="info-value"><a href={info.homepage} target="_blank" rel="noopener noreferrer">{info.homepage}</a></span></>}
        </div>

        {(info?.gold_count != null || info?.silver_count != null || info?.bronze_count != null || info?.hm_count != null) && (
          <>
            <h3>Awards</h3>
            <div class="info-grid">
              {info?.gold_count != null && <><span class="info-label award-gold-medal">Gold</span><span class="info-value">{info.gold_count}{info.gold_cutoff != null && <span class="info-cutoff"> (&ge; {info.gold_cutoff} pts)</span>}</span></>}
              {info?.silver_count != null && <><span class="info-label award-silver-medal">Silver</span><span class="info-value">{info.silver_count}{info.silver_cutoff != null && <span class="info-cutoff"> (&ge; {info.silver_cutoff} pts)</span>}</span></>}
              {info?.bronze_count != null && <><span class="info-label award-bronze-medal">Bronze</span><span class="info-value">{info.bronze_count}{info.bronze_cutoff != null && <span class="info-cutoff"> (&ge; {info.bronze_cutoff} pts)</span>}</span></>}
              {info?.hm_count != null && <><span class="info-label award-honourable-mention">Hon. Mention</span><span class="info-value">{info.hm_count}</span></>}
            </div>
          </>
        )}
      </div>
    )}
  </div>
</Layout>

<style>
  .info-label.award-gold-medal { color: var(--medal-gold); }
  .info-label.award-silver-medal { color: var(--medal-silver); }
  .info-label.award-bronze-medal { color: var(--medal-bronze); }
  .info-label.award-honourable-mention { color: var(--medal-hm); }
  .info-cutoff {
    color: var(--text-secondary);
    font-weight: 400;
  }
</style>
