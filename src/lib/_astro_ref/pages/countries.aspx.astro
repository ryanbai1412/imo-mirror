---
import Layout from "../layouts/Layout.astro";
import { loadCountries } from "../utils/data";
import { sortData, parseSortParams } from "../utils/sort";
import SortableTableHead from "../components/SortableTableHead.astro";

const origin = Astro.url.origin;
const countries = await loadCountries(origin);
const { column, order } = parseSortParams(Astro.url.searchParams);
const sorted = column ? sortData(countries, column, order) : countries;

const cols = [
  { key: "code", label: "Code" },
  { key: "name", label: "Country" },
  { key: "flag", label: "Flag", sortable: false },
  { key: "website", label: "Website", sortable: false },
];
---

<Layout title="Countries" description="All countries participating in the International Mathematical Olympiad. Contact information, websites, and hosting history." path="/countries.aspx">
  <div class="page-content">
    <h2>Countries</h2>
    <div class="table-container">
      <table class="data-table">
        <SortableTableHead cols={cols} url={Astro.url} column={column} order={order} />
        <tbody>
          {sorted.map((c) => (
            <tr>
              <td><a href={`/country_info.aspx?code=${c.code}`}>{c.code}</a></td>
              <td><a href={`/country_info.aspx?code=${c.code}`}>{c.name}</a></td>
              <td>{c.flag_url ? <img src={c.flag_url} alt={c.code} class="country-flag" /> : ""}</td>
              <td>{c.website ? <a href={c.website} target="_blank" rel="noopener noreferrer">Link</a> : ""}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>
