---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { loadCountryResultsByYear, loadTimeline } from "../utils/data";
import { sortData, parseSortParams } from "../utils/sort";
import { CHART_COLORS } from "../utils/chartColors";
import { yearNavItems } from "../utils/nav";
import SortableTableHead from "../components/SortableTableHead.astro";

const origin = Astro.url.origin;
const year = Astro.url.searchParams.get("year") || "";
if (!year) return Astro.redirect("/results_year.aspx");

const [countryResults, timeline] = await Promise.all([
  loadCountryResultsByYear(origin),
  loadTimeline(origin),
]);

const results = countryResults[year] || [];
const yearNum = Number(year);
const sortedYears = timeline.map(t => t.year).sort((a, b) => a - b);
const prevYear = timeline.find(t => t.year === sortedYears.filter(y => y < yearNum).pop());
const nextYear = timeline.find(t => t.year === sortedYears.find(y => y > yearNum));
const { column, order } = parseSortParams(Astro.url.searchParams);
const sorted = column ? sortData(results, column, order) : results;

const binSize = 10;
const maxPossible = 252;
const numBins = Math.ceil(maxPossible / binSize) + 1;
const countryBins: number[] = Array(numBins).fill(0);
const binRanks: { min: number; max: number }[] = Array.from({ length: numBins }, () => ({ min: Infinity, max: -Infinity }));
for (const r of results) {
  if (r.total == null) continue;
  const bin = Math.min(Math.floor(r.total / binSize), numBins - 1);
  countryBins[bin]++;
  if (r.rank != null) {
    binRanks[bin].min = Math.min(binRanks[bin].min, r.rank);
    binRanks[bin].max = Math.max(binRanks[bin].max, r.rank);
  }
}
const countryDistData = JSON.stringify(
  countryBins.map((count, i) => ({
    label: `${i * binSize}–${i * binSize + binSize - 1}`,
    lo: i * binSize,
    count,
    rankMin: binRanks[i].min === Infinity ? null : binRanks[i].min,
    rankMax: binRanks[i].max === -Infinity ? null : binRanks[i].max,
  }))
);
const chartColorsJson = JSON.stringify(CHART_COLORS);

const hasP7 = results.some(r => r.p7 != null);

const cols = [
  { key: "rank", label: "Rank", align: "center" },
  { key: "country", label: "Country" },
  { key: "code", label: "Code" },
  { key: "team_size_all", label: "#", title: "Team size", align: "center", defaultOrder: "desc" as const },
  { key: "p1", label: "P1", title: "Problem 1", align: "center", defaultOrder: "desc" as const },
  { key: "p2", label: "P2", title: "Problem 2", align: "center", defaultOrder: "desc" as const },
  { key: "p3", label: "P3", title: "Problem 3", align: "center", defaultOrder: "desc" as const },
  { key: "p4", label: "P4", title: "Problem 4", align: "center", defaultOrder: "desc" as const },
  { key: "p5", label: "P5", title: "Problem 5", align: "center", defaultOrder: "desc" as const },
  { key: "p6", label: "P6", title: "Problem 6", align: "center", defaultOrder: "desc" as const },
  ...(hasP7 ? [{ key: "p7", label: "P7", title: "Problem 7", align: "center", defaultOrder: "desc" as const }] : []),
  { key: "total", label: "Total", align: "center", defaultOrder: "desc" as const },
  { key: "awards_gold", label: "G", title: "Gold medals", align: "center", defaultOrder: "desc" as const },
  { key: "awards_silver", label: "S", title: "Silver medals", align: "center", defaultOrder: "desc" as const },
  { key: "awards_bronze", label: "B", title: "Bronze medals", align: "center", defaultOrder: "desc" as const },
  { key: "awards_hm", label: "HM", title: "Honourable Mention", align: "center", defaultOrder: "desc" as const },
  { key: "leader", label: "Leader" },
  { key: "deputy_leader", label: "Deputy Leader" },
];
---

<Layout title={`IMO ${year} - Country Results`} description={`Country results for the ${year} International Mathematical Olympiad. Rankings, scores, and medal counts for all participating countries.`} path={`/year_country_r.aspx?year=${year}`}>
  <div class="page-content">
    <PageHeader title={`IMO ${year} — Country Results`} navItems={yearNavItems(year)} currentPath={`/year_country_r.aspx?year=${year}`}
      prevHref={prevYear ? `/year_country_r.aspx?year=${prevYear.year}` : undefined}
      nextHref={nextYear ? `/year_country_r.aspx?year=${nextYear.year}` : undefined}
    />

    {results.length > 0 && (
      <div class="stats-section">
        <h3>Country Score Distribution</h3>
        <div class="chart-wrapper">
          <canvas id="country-dist-chart" width="700" height="320"></canvas>
        </div>
      </div>
    )}

    <div class="table-container">
      <table class="data-table">
        <SortableTableHead cols={cols} url={Astro.url} column={column} order={order} />
        <tbody>
          {sorted.map((row) => (
            <tr>
              <td class="text-center">{row.rank ?? ""}</td>
              <td><a href={`/team_r.aspx?code=${row.code}&year=${year}`}>{row.country}</a></td>
              <td><a href={`/team_r.aspx?code=${row.code}&year=${year}`}>{row.code}</a></td>
              <td class="text-center">{row.team_size_all ?? ""}</td>
              <td class="text-center">{row.p1 ?? ""}</td>
              <td class="text-center">{row.p2 ?? ""}</td>
              <td class="text-center">{row.p3 ?? ""}</td>
              <td class="text-center">{row.p4 ?? ""}</td>
              <td class="text-center">{row.p5 ?? ""}</td>
              <td class="text-center">{row.p6 ?? ""}</td>
              {hasP7 && <td class="text-center">{row.p7 ?? ""}</td>}
              <td class="text-center">{row.total ?? ""}</td>
              <td class="text-center">{row.awards_gold ? <span class="award-gold-medal">{row.awards_gold}</span> : ""}</td>
              <td class="text-center">{row.awards_silver ? <span class="award-silver-medal">{row.awards_silver}</span> : ""}</td>
              <td class="text-center">{row.awards_bronze ? <span class="award-bronze-medal">{row.awards_bronze}</span> : ""}</td>
              <td class="text-center">{row.awards_hm ? <span class="award-honourable-mention">{row.awards_hm}</span> : ""}</td>
              <td>{row.leader || ""}</td>
              <td>{row.deputy_leader || ""}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ countryDistData, year, chartColorsJson }}>
var CC = JSON.parse(chartColorsJson);
function drawCountryDistChart() {
  var data = JSON.parse(countryDistData);
  var pad = { top: 30, right: 16, bottom: 48, left: 40 };
  var c = chartSetup('country-dist-chart', CC, 0, 320, pad);
  if (!c) return;
  var ctx = c.ctx, canvas = c.canvas, cw = c.cw, ch = c.ch, W = c.W, H = c.H;
  var last = data.findLastIndex(function(d) { return d.count > 0; });
  var visible = data.slice(0, Math.max(last + 2, 10));
  var maxCount = visible.reduce(function(m, d) { return Math.max(m, d.count); }, 0);
  var yMax = Math.ceil(maxCount / 5) * 5 || 5;
  var barW = cw / visible.length;
  var gap = Math.max(1, barW * 0.15);
  drawYGrid(ctx, CC, pad, W, ch, yMax);
  for (var i = 0; i < visible.length; i++) {
    var d = visible[i];
    var x = pad.left + i * barW + gap / 2;
    var bw = barW - gap;
    if (d.count > 0) {
      var h = (d.count / yMax) * ch;
      ctx.fillStyle = CC.line;
      ctx.fillRect(x, pad.top + ch - h, bw, h);
    }
    ctx.fillStyle = CC.label;
    ctx.textAlign = 'center';
    ctx.font = '10px system-ui, sans-serif';
    ctx.fillText(String(d.lo), x + bw / 2, pad.top + ch + 14);
  }
  drawTitle(ctx, CC, 'Country total score \u2014 IMO ' + year, W, pad);
  ctx.font = '11px system-ui, sans-serif';
  ctx.fillStyle = CC.label;
  ctx.fillText('Total Score', W / 2, H - 4);
  setupTooltip(canvas, visible, W, H, pad, ch, {
    getIdx: barGetIdx(pad, barW),
    isHidden: function(my, idx) {
      var d0 = visible[idx];
      if (!d0.count) return true;
      return my < pad.top + ch - (d0.count / yMax) * ch;
    },
    getHtml: function(d) {
      var html = '<b>' + d.label + ' pts</b><br>' + d.count + (d.count === 1 ? ' country' : ' countries');
      var rl = rankLabel(d.rankMin, d.rankMax);
      if (rl) html += '<br>' + rl;
      return html;
    }
  });
}
drawCountryDistChart();
document.addEventListener('astro:page-load', drawCountryDistChart);
</script>
