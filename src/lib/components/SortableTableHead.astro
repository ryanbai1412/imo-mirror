---
import { getSortUrl, sortIndicator } from "../utils/sort";
import type { SortDirection } from "../utils/sort";

interface ColDef {
  key: string;
  label: string;
  title?: string;
  align?: string;
  defaultOrder?: SortDirection;
  sortable?: boolean;
}

interface Props {
  cols: ColDef[];
  url: URL;
  column: string;
  order: SortDirection;
}

const { cols, url, column, order } = Astro.props;
---

<thead>
  <tr>
    {cols.map(col => {
      const sortable = col.sortable !== false;
      return (
        <th class:list={[col.align === "center" && "text-center", sortable && "sortable-header"]} title={col.title}>
          {sortable ? (
            <a href={getSortUrl(url, col.key, col.defaultOrder)}>{col.label}{sortIndicator(col.key, column, order)}</a>
          ) : (
            col.label
          )}
        </th>
      );
    })}
    <slot />
  </tr>
</thead>
