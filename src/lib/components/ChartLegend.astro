---
interface Props {
  items: { color: string; label: string; line?: boolean }[];
}

const { items } = Astro.props;
---

<div class="chart-legend">
  {items.map(item => (
    <span class="legend-item">
      <span class:list={["legend-swatch", item.line && "legend-line"]} style={`background:${item.color}`}></span>
      {item.label}
    </span>
  ))}
</div>
