---
import { awardClass, awardType } from "../utils/awardClass";

interface Props {
  award: string;
}

const { award } = Astro.props;

const parts = award.split(/,\s*/);
const medalPart = parts.find(p => awardType(p) !== "none");
const otherParts = parts.filter(p => p !== medalPart && p !== "");
---

{medalPart && <span class={awardClass(medalPart)}>{medalPart}</span>}{otherParts.length > 0 && `, ${otherParts.join(", ")}`}
