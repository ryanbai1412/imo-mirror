---
import { isIndividualContestant } from "../utils/data";

interface Props {
  code: string;
  label?: string;
  year?: string | number;
}

const { code, label, year } = Astro.props;
const codes = code.split(",").map(c => c.trim()).filter(Boolean);
const visibleCodes = codes.filter(c => !isIndividualContestant(c));
const href = (c: string) => year
  ? `/team_r.aspx?code=${c}&year=${year}`
  : `/country_info.aspx?code=${c}`;
---

{visibleCodes.length === 0 ? (
  <Fragment />
) : visibleCodes.length === 1 ? (
<a href={href(visibleCodes[0])}>{label && !isIndividualContestant(codes[0]) ? label : visibleCodes[0]}</a>
) : (
  visibleCodes.map((c, i) => (
    <>{i > 0 && ", "}<a href={href(c)}>{c}</a></>
  ))
)}
